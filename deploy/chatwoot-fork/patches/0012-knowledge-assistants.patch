@@ -0,0 +1,44 @@
+<!-- AssistantSelector.vue — a small labeled <select> bound to the shared
+     useKnowledgeAssistant composable. Drop this into any Knowledge page header
+     that needs the user to pick an assistant. State is module-level so all
+     pages stay in sync without prop-drilling. -->
+<script setup>
+import { onMounted } from 'vue';
+import { useKnowledgeAssistant } from 'dashboard/composables/useKnowledgeAssistant';
+
+const { assistants, selectedId, refresh, select } = useKnowledgeAssistant();
+
+const onChange = event => {
+  select(event.target.value);
+};
+
+onMounted(() => {
+  if (!assistants.value.length) {
+    refresh();
+  }
+});
+</script>
+
+<template>
+  <div class="flex items-center gap-2">
+    <label class="text-xs font-medium text-n-slate-11 whitespace-nowrap">
+      Assistant
+    </label>
+    <select
+      :value="selectedId"
+      class="px-2 py-1 text-sm border rounded-lg border-n-weak bg-n-alpha-black1 text-n-slate-12 focus:outline-none"
+      @change="onChange"
+    >
+      <option v-if="!assistants.length" value="" disabled>
+        Loading…
+      </option>
+      <option
+        v-for="assistant in assistants"
+        :key="assistant.id"
+        :value="String(assistant.id)"
+      >
+        {{ assistant.name }}
+      </option>
+    </select>
+  </div>
+</template>
diff --git a/app/javascript/dashboard/components/proton/KnowledgeAssistants.vue b/app/javascript/dashboard/components/proton/KnowledgeAssistants.vue
new file mode 100644
index 0000000..7d46d06
