# Copy this file to deploy/.env and fill in real values before running:
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d

# ---------------------------------------------------------------------------
# Platform
# ---------------------------------------------------------------------------

# GCE VM external IP in dash form, used to build nip.io hostnames
# (crm.<PUBLIC_IP>.nip.io, tickets.<PUBLIC_IP>.nip.io, ...), e.g. 34-101-1-2
PUBLIC_IP=changeme

# ---------------------------------------------------------------------------
# Shared infrastructure secrets
# ---------------------------------------------------------------------------

# Password for the postgres superuser (also used by chatwoot's POSTGRES_PASSWORD)
POSTGRES_PASSWORD=changeme

# Password for the "zammad" postgres role/database
ZAMMAD_DB_PASSWORD=changeme

# Password for the "agent" postgres role/database
AGENT_DB_PASSWORD=changeme

# WARNING: Do not use single quotes (') in any password variables below.
# The postgres init script interpolates these values into SQL string literals,
# and single quotes will cause SQL injection or parsing errors.

# Shared password for the redis instance (used --requirepass style by all consumers)
REDIS_PASSWORD=changeme

# Chatwoot Rails secret_key_base. Generate with: openssl rand -hex 64
SECRET_KEY_BASE=changeme

# ---------------------------------------------------------------------------
# Agent service (deploy/../agent — FastAPI integration service, Task 3)
# ---------------------------------------------------------------------------

# Internal URLs — leave as-is, they resolve via the platform docker network
CHATWOOT_URL=http://chatwoot-rails:3000
ZAMMAD_URL=http://zammad-nginx:8080

# Public URL of this agent service; used by scripts/register_bot.py as the base for the Chatwoot agent-bot outgoing_url
AGENT_PUBLIC_URL=http://agent.${PUBLIC_IP}.nip.io

# Chatwoot → Profile Settings → Access Token (agent bot/API user)
CHATWOOT_API_TOKEN=
# Chatwoot → Super Admin → Platform Apps → Platform Token
CHATWOOT_PLATFORM_TOKEN=
# Chatwoot account id the agent operates against
CHATWOOT_ACCOUNT_ID=1

# Zammad → Profile → Token Access → API token for the integration user
ZAMMAD_API_TOKEN=

# Google AI Studio → Get API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Shared secret configured on the Chatwoot webhook that calls the agent
CHATWOOT_WEBHOOK_SECRET=
# Chatwoot → Agent Bot → generated bot secret/token pair
CHATWOOT_BOT_SECRET=
CHATWOOT_BOT_TOKEN=
# Shared secret configured on the Zammad webhook/trigger that calls the agent
ZAMMAD_WEBHOOK_SECRET=
# Zammad user (email) the integration acts as when creating/updating tickets
ZAMMAD_INTEGRATION_LOGIN=integration@local

# "suggest" = draft replies for human approval, "auto" = send without review
AGENT_MODE=suggest
# Whether the agent may resolve/close tickets on its own
AUTO_RESOLVE=false

# Enables AI-drafted internal reply notes on Zammad tickets when a customer writes (set false to disable)
ZAMMAD_AI_DRAFTS=true

# Agent service's own database (role/db created by deploy/postgres/init/01-databases.sh)
AGENT_DATABASE_URL=postgresql+psycopg://agent:${AGENT_DB_PASSWORD}@postgres:5432/agent
