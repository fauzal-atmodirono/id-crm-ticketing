diff --git a/app/javascript/dashboard/api/protonMetrics.js b/app/javascript/dashboard/api/protonMetrics.js
new file mode 100644
index 0000000..b539073
--- /dev/null
+++ b/app/javascript/dashboard/api/protonMetrics.js
@@ -0,0 +1,61 @@
+import { useProtonConfig } from 'dashboard/composables/useProtonConfig';
+
+// Thin client for the Proton backend Metrics endpoints (/metrics/*). Auth is
+// the shared PROTON_BACKEND_KEY sent as x-api-key; required for gated
+// endpoints (departments, callcenter, lifecycle) and harmless for the open
+// ones (dashboard, anomalies). Errors carry a numeric `.status` so callers
+// can special-case 401/503.
+async function metricsRequest(path) {
+  const { backendUrl, backendKey } = useProtonConfig();
+  if (!backendUrl) throw new Error('PROTON_BACKEND_URL not configured');
+
+  const response = await fetch(`${backendUrl}${path}`, {
+    headers: {
+      'Content-Type': 'application/json',
+      ...(backendKey ? { 'x-api-key': backendKey } : {}),
+    },
+  });
+
+  if (!response.ok) {
+    const text = await response.text().catch(() => response.statusText);
+    const err = new Error(`${response.status}: ${text.slice(0, 200)}`);
+    err.status = response.status;
+    throw err;
+  }
+  const text = await response.text();
+  return text ? JSON.parse(text) : {};
+}
+
+// GET /metrics/dashboard -> summary metrics for the overview panel
+export function getDashboard() {
+  return metricsRequest('/metrics/dashboard');
+}
+
+// GET /metrics/anomalies -> detected anomaly list
+export function getAnomalies() {
+  return metricsRequest('/metrics/anomalies');
+}
+
+// GET /metrics/departments -> { dept_pic_performance: [], reopen_rate: [] }
+export function getDepartments() {
+  return metricsRequest('/metrics/departments');
+}
+
+// GET /metrics/callcenter -> { sla_achievement: [], tasks_per_agent: [],
+//   first_response_by_channel: [], resolution_time: [], complaint_type_ranking: [],
+//   peak_hours: [], nps_by_agent: [] }
+export function getCallCentre() {
+  return metricsRequest('/metrics/callcenter');
+}
+
+// GET /metrics/lifecycle -> { case_lifecycle: [], state_trend: [] }
+export function getLifecycle() {
+  return metricsRequest('/metrics/lifecycle');
+}
+
+// Returns a URL string for opening /metrics/export in a new tab.
+// format: 'csv' | 'xlsx'
+export function exportUrl(format) {
+  const { backendUrl } = useProtonConfig();
+  return `${backendUrl}/metrics/export?format=${format}`;
+}
