+// ── Scenarios ─────────────────────────────────────────────────────────────────
+
+// GET /kb/scenarios?assistant_id=<id> -> [{ id, assistant_id, title,
+//   description, instruction, tools: [slug], enabled, created_at }]
+export async function listScenarios(assistantId) {
+  const data = await kbRequest(
+    `/kb/scenarios?assistant_id=${encodeURIComponent(assistantId)}`
+  );
+  return Array.isArray(data.scenarios) ? data.scenarios : [];
+}
+
+// body: { assistant_id, title, description, instruction, tools: [slug], enabled }
+// -> { id }   422 if unknown tool slug; 422 if instruction > 4096; 409 if > 20 per assistant
+export function createScenario(body) {
+  return kbRequest('/kb/scenarios', { method: 'POST', body });
+}
+
+// PUT /kb/scenarios/{id}  partial update
+export function updateScenario(id, body) {
+  return kbRequest(`/kb/scenarios/${encodeURIComponent(id)}`, {
+    method: 'PUT',
+    body,
+  });
+}
+
+// DELETE /kb/scenarios/{id}
+export function deleteScenario(id) {
+  return kbRequest(`/kb/scenarios/${encodeURIComponent(id)}`, {
+    method: 'DELETE',
+  });
+}
+
 // ── Tenant settings ───────────────────────────────────────────────────────────
 
 // GET /kb/settings -> { <key>: { value, source: "override"|"env" } }
