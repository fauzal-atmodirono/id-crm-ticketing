+const sortedDeptPic = computed(() =>
+  [...deptPic.value].sort((a, b) => (b.cases ?? 0) - (a.cases ?? 0))
+);
+
+// ── Top-N depts by total cases (aggregate across PICs) ───────────────────────
+
+const TOP_N = 10;
