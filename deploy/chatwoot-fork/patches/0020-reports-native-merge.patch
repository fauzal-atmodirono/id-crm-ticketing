diff --git a/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonAnomaly.vue b/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonAnomaly.vue
new file mode 100644
index 0000000..e2fc391
--- /dev/null
+++ b/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonAnomaly.vue
@@ -0,0 +1,180 @@
+<script setup>
+import { ref, onMounted } from 'vue';
+import ReportMetricCard from './components/ReportMetricCard.vue';
+import { getAnomalies } from 'dashboard/api/protonMetrics';
+
+// ── Data ──────────────────────────────────────────────────────────────────────
+
+const anomalies = ref([]);
+const error = ref(null);
+const loading = ref(true);
+
+onMounted(async () => {
+  try {
+    const result = await getAnomalies();
+    anomalies.value = result.anomalies ?? [];
+  } catch (e) {
+    error.value = e.message || 'Failed to load anomaly data';
+  } finally {
+    loading.value = false;
+  }
+});
+
+// ── Helpers ───────────────────────────────────────────────────────────────────
+
+const fmt = (n, decimals = 1) => {
+  if (n == null || Number.isNaN(Number(n))) return '—';
+  return Number(n).toLocaleString(undefined, {
+    minimumFractionDigits: decimals,
+    maximumFractionDigits: decimals,
+  });
+};
+
+const computeDeviation = row => {
+  const { current_volume, baseline_mean, baseline_stddev } = row;
+  if (
+    !baseline_stddev ||
+    baseline_stddev === 0 ||
+    baseline_mean == null ||
+    current_volume == null
+  ) {
+    return null;
+  }
+  return (current_volume - baseline_mean) / baseline_stddev;
+};
+
+const BADGE_NEUTRAL =
+  'inline-flex items-center justify-center px-2 py-0.5 rounded text-xs font-medium bg-n-alpha-2 text-n-slate-11';
+const BADGE_WARN =
+  'inline-flex items-center justify-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400';
+const BADGE_DANGER =
+  'inline-flex items-center justify-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400';
+
+const deviationBadgeClass = deviation => {
+  if (deviation == null) return BADGE_NEUTRAL;
+  const abs = Math.abs(deviation);
+  if (abs >= 3) return BADGE_DANGER;
+  if (abs >= 2) return BADGE_WARN;
+  return BADGE_NEUTRAL;
+};
+</script>
+
+<template>
+  <div class="flex flex-col gap-6 px-6 py-5">
+    <!-- Loading state -->
+    <woot-loading-state
+      v-if="loading"
+      class="text-xs"
+      message="Loading anomaly data…"
+    />
+
+    <!-- Error state -->
+    <div
+      v-else-if="error"
+      class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+    >
+      {{ error }}
+    </div>
+
+    <template v-else>
+      <!-- KPI card: flagged channel count -->
+      <div
+        class="flex flex-wrap mx-0 shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5 gap-4"
+      >
+        <ReportMetricCard
+          label="Flagged Channels"
+          info-text="Number of channels with anomalous volume detected"
+          :value="String(anomalies.length)"
+          class="flex-1"
+        />
+      </div>
+
+      <!-- Anomaly table -->
+      <div
+        class="shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5"
+      >
+        <h3 class="text-sm font-semibold text-n-slate-12 mb-4">
+          Flagged Channels
+        </h3>
+
+        <!-- Empty state -->
+        <div
+          v-if="!anomalies.length"
+          class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+        >
+          No anomalies detected
+        </div>
+
+        <!-- Table -->
+        <div v-else class="overflow-x-auto">
+          <table class="w-full text-sm">
+            <thead>
+              <tr class="border-b border-n-container">
+                <th
+                  class="text-left py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Channel
+                </th>
+                <th
+                  class="text-right py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Current Volume
+                </th>
+                <th
+                  class="text-right py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Baseline Mean
+                </th>
+                <th
+                  class="text-right py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Baseline Std Dev
+                </th>
+                <th
+                  class="text-right py-2 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Deviation
+                </th>
+              </tr>
+            </thead>
+            <tbody>
+              <tr
+                v-for="row in anomalies"
+                :key="row.channel"
+                class="border-b border-n-container last:border-0"
+              >
+                <td class="py-3 pr-4 text-n-slate-12 capitalize">
+                  {{ row.channel }}
+                </td>
+                <td class="py-3 pr-4 text-right text-n-slate-12">
+                  {{ fmt(row.current_volume, 0) }}
+                </td>
+                <td class="py-3 pr-4 text-right text-n-slate-11">
+                  {{
+                    row.baseline_mean != null ? fmt(row.baseline_mean, 1) : '—'
+                  }}
+                </td>
+                <td class="py-3 pr-4 text-right text-n-slate-11">
+                  {{
+                    row.baseline_stddev != null
+                      ? fmt(row.baseline_stddev, 1)
+                      : '—'
+                  }}
+                </td>
+                <td class="py-3 text-right">
+                  <span :class="deviationBadgeClass(computeDeviation(row))">
+                    {{
+                      computeDeviation(row) != null
+                        ? fmt(computeDeviation(row), 2)
+                        : '—'
+                    }}
+                  </span>
+                </td>
+              </tr>
+            </tbody>
+          </table>
+        </div>
+      </div>
+    </template>
+  </div>
+</template>
diff --git a/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonCaseLifecycle.vue b/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonCaseLifecycle.vue
new file mode 100644
index 0000000..c0ceaea
--- /dev/null
+++ b/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonCaseLifecycle.vue
@@ -0,0 +1,294 @@
+<script setup>
+import { ref, computed, onMounted } from 'vue';
+import BarChart from 'shared/components/charts/BarChart.vue';
+import LineChart from 'shared/components/charts/LineChart.vue';
+import { getLifecycle } from 'dashboard/api/protonMetrics';
+
+// ── Data ──────────────────────────────────────────────────────────────────────
+
+const cases = ref([]);
+const stateTrend = ref([]);
+const error = ref(null);
+const loading = ref(true);
+
+onMounted(async () => {
+  try {
+    const result = await getLifecycle();
+    cases.value = result.cases ?? [];
+    stateTrend.value = result.state_trend ?? [];
+  } catch (e) {
+    error.value = e.message || 'Failed to load lifecycle data';
+  } finally {
+    loading.value = false;
+  }
+});
+
+// ── Helpers ───────────────────────────────────────────────────────────────────
+
+const fmtMin = n => {
+  if (n == null || Number.isNaN(Number(n))) return '—';
+  return Number(n).toLocaleString(undefined, {
+    minimumFractionDigits: 0,
+    maximumFractionDigits: 0,
+  });
+};
+
+// ── Section 1: Resolution-time distribution histogram ─────────────────────────
+
+const BUCKET_LABELS = [
+  '0–30m',
+  '30–60m',
+  '1–2h',
+  '2–4h',
+  '4–8h',
+  '8–24h',
+  '>24h',
+];
+
+// Returns bucket index (0–6) given resolution_minutes value
+function bucketIndex(minutes) {
+  const m = Number(minutes);
+  if (m < 30) return 0;
+  if (m < 60) return 1;
+  if (m < 120) return 2;
+  if (m < 240) return 3;
+  if (m < 480) return 4;
+  if (m < 1440) return 5;
+  return 6;
+}
+
+const resolutionHistogramCollection = computed(() => {
+  const valid = cases.value.filter(
+    c =>
+      c.resolution_minutes != null &&
+      !Number.isNaN(Number(c.resolution_minutes))
+  );
+  if (!valid.length) return null;
+
+  const counts = new Array(7).fill(0);
+  valid.forEach(c => {
+    counts[bucketIndex(c.resolution_minutes)] += 1;
+  });
+
+  return {
+    labels: BUCKET_LABELS,
+    datasets: [
+      {
+        label: 'Cases',
+        backgroundColor: '#6366f1',
+        data: counts,
+      },
+    ],
+  };
+});
+
+const barChartOptions = {
+  plugins: { legend: { display: false } },
+  scales: { y: { beginAtZero: true } },
+};
+
+// ── Section 2: State trend LineChart ──────────────────────────────────────────
+
+// Palette for trend lines — cycles if more statuses than colours
+const LINE_COLORS = [
+  '#6366f1',
+  '#22c55e',
+  '#f59e0b',
+  '#ef4444',
+  '#3b82f6',
+  '#a855f7',
