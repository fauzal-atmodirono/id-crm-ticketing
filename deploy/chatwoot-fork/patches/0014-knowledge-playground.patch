+// ── Playground ────────────────────────────────────────────────────────────────
+
+// POST /assist/copilot  body: { conversation_id, thread, assistant_id }
+// Returns { answer, tool_calls: [string], sources: [{ title, snippet, url }] }.
+// conversationId defaults to "playground" so the backend's context tools
+// short-circuit gracefully when no real conversation is targeted.
+export function askPlayground(assistantId, thread, conversationId) {
+  return kbRequest('/assist/copilot', {
+    method: 'POST',
+    body: {
+      conversation_id: conversationId || 'playground',
+      thread,
+      assistant_id: assistantId,
+    },
+  });
+}
+
