# Application Configurations
CRM_PROVIDER=chatwoot
VOICE_PROVIDER=mock
PORT=8000
HOST=127.0.0.1
DEBUG=true

# Frontend CORS allowlist (comma-separated; Vite picks the next free port if
# 5173 is taken, so we list the common fallbacks by default).
FRONTEND_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:5175","http://localhost:5176","http://localhost:5177","http://localhost:5178","http://localhost:5179","http://localhost:5180"]

# Google Cloud / Gemini Settings
GOOGLE_GENAI_USE_VERTEXAI=false
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Gemini TTS (via Cloud Text-to-Speech API)
GEMINI_TTS_MODEL=gemini-2.5-flash-tts
GEMINI_TTS_VOICE=Kore
VOICE_DEFAULT_LANG=en-US

# Zendesk CRM Settings
ZENDESK_SUBDOMAIN=your-zendesk-subdomain
ZENDESK_EMAIL=admin@your-domain.com
ZENDESK_APP_ID=your-zendesk-app-id
ZENDESK_KEY_ID=your-zendesk-key-id
ZENDESK_SECRET_KEY=your-zendesk-secret-key
ZENDESK_API_TOKEN=your-zendesk-api-token
# Per-customer identity when SHARING one Zendesk instance across brands.
# Override per fork so tickets/end-users stay distinguishable and triggers
# can route webhooks by tag. Leave the tag empty for a dedicated instance.
ZENDESK_REQUESTER_DOMAIN=proton.devoteam.example
ZENDESK_CUSTOMER_NAME_PREFIX=Proton AI Customer
ZENDESK_TICKET_TAG=

# Chatwoot & Zammad Settings (open-source alternative)
CHATWOOT_API_URL=http://localhost:3000
CHATWOOT_API_TOKEN=mock-chatwoot-token
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_ENABLED=true
# API-channel inbox our backend opens conversations in / receives webhooks from.
# 0 = unset (the adapter fails fast). Also used for shared-account inbox isolation.
CHATWOOT_INBOX_ID=0
# Team the escalated conversation is assigned to (the native-inbox handoff).
CHATWOOT_AGENT_TEAM_ID=0
# Always-applied escalation marker (Chatwoot-only, does NOT open a ticket).
CHATWOOT_ESCALATION_LABEL=ai-escalation
# Complaint-only label the shared instance's sync turns into a Zammad ticket.
# Applied on top of the marker ONLY for complaints (see reasons), so plain
# "talk to a human" handoffs stay live-chat-only. Empty = never open a ticket.
CHATWOOT_COMPLAINT_LABEL=escalate
# Comma-separated HandoffReason values treated as complaints. High urgency also
# counts. help_request / sales_lead / unknown_retry_limit stay chat-only.
CHATWOOT_COMPLAINT_REASONS=negative_sentiment
# Shared secret gating inbound /webhooks/chatwoot (?token=<secret> or header).
# Empty leaves the endpoint open. Chatwoot has no built-in HMAC.
CHATWOOT_WEBHOOK_SECRET=
# Domain for synthesized contact emails (<sanitized session_id>@<domain>) —
# downstream email-keyed ticketing needs one. Use a real TLD for format validity.
CHATWOOT_CUSTOMER_EMAIL_DOMAIN=proton-demo.my
# Whether an INCOMING message runs the AI. False for a handoff-console deployment
# (customers on web/WhatsApp, Chatwoot only for agents); True only when Chatwoot
# itself is the customer channel (website widget).
CHATWOOT_BOT_REPLIES_TO_INCOMING=false
# EMAIL-type Chatwoot inbox id. When set (non-zero), an incoming email that lands
# in this inbox is routed to the email flow: the AI answers and the reply is
# posted as a PUBLIC message so Chatwoot emails it to the customer. 0 = disabled.
# Honours EMAIL_DRAFT_ASSIST (private draft note instead of a public send).
CHATWOOT_EMAIL_INBOX_ID=0

ZAMMAD_API_URL=http://localhost:3000
ZAMMAD_API_TOKEN=mock-zammad-token
ZAMMAD_ENABLED=true
# When true, the backend creates the Zammad ticket DIRECTLY on a complaint and
# does NOT apply the Chatwoot `escalate` label (avoids a double-ticket if the
# external agent-service sync is ever wired). false = legacy label-only behavior.
ZAMMAD_DIRECT_TICKETING=true
ZAMMAD_GROUP=Users

# Vertex AI Search (Discovery Engine)
KNOWLEDGE_PROVIDER=mock                # mock | zendesk | vertex_search
VERTEX_SEARCH_PROJECT_ID=
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_DATA_STORE_ID=
VERTEX_SEARCH_ENGINE_ID=

# Sunshine Conversations webhook HMAC secret (used to verify inbound
# webhook signatures). Configured in the SC dashboard.
SUNSHINE_WEBHOOK_SECRET=

# Handoff bridge persistence
HANDOFF_STORE=memory                   # memory | firestore
FIRESTORE_PROJECT_ID=lv-playground-genai
FIRESTORE_DATABASE_ID=proton-db
FIRESTORE_HANDOFF_COLLECTION=handoff_sessions

# Case audit trail (SLA escalation tracking)
FIRESTORE_AUDIT_COLLECTION=case_audit_log

# --- Real-time, CRM-editable FAQ knowledge base (semantic matching) ---
# CRM team authors FAQ entries via POST/PUT/DELETE /kb/faq; each write embeds the
# entry (question + answer) with EMBEDDING_MODEL and stores the vector in
# LIVE_FAQ_COLLECTION (Firestore, same DB as the handoff store — auto-created on
# first write, no vector index needed). /kb/suggest merges live-FAQ semantic hits
# with the Vertex-Search KB. Admin writes require x-api-key == FAQ_ADMIN_API_KEY
# (constant-time compared); empty = every write 401s.
FAQ_ADMIN_API_KEY=
LIVE_FAQ_COLLECTION=live_faq
EMBEDDING_MODEL=text-embedding-004

# --- Proton assist endpoints -----------------------------------------------
# Shared secret for /assist/* endpoints (must match PROTON_BACKEND_KEY in tenant env).
# Empty means endpoints are unconfigured; boot fails gracefully (endpoints return 503).
PROTON_BACKEND_KEY=
# Gemini model for summarize/ask; defaults to the same model as the main agent.
ASSIST_GEMINI_MODEL=gemini-2.5-flash
# Chatwoot origins allowed to call /assist/* cross-origin.
ASSIST_CORS_ORIGINS=[]

# --- Ask Copilot -------------------------------------------------------------
COPILOT_GEMINI_MODEL=gemini-2.5-flash
COPILOT_MAX_TOOL_ITERATIONS=5

# SLA escalation webhook secret (used to verify inbound webhook signatures)
SLA_WEBHOOK_SECRET=

# --- SLA-timer escalation engine (Chatwoot has no native SLA engine) ---
# Master switch for the in-app SLA scan scheduler (default OFF: nothing scans).
SLA_ENGINE_ENABLED=false
# First-response SLA: OPEN + no agent reply older than this many hours -> breach.
SLA_RESPONSE_HOURS=8
# Resolution SLA: not-resolved older than this many hours -> breach (a per-
# conversation sla_<int> label/attribute in MINUTES overrides this default).
SLA_RESOLUTION_HOURS=48
# How often (minutes) the scan job runs.
SLA_SCAN_INTERVAL_MINUTES=15
# Optional PIC WhatsApp number (E.164) alerted via Twilio on each breach. Empty
# records the audit transition only (no alert).
SLA_PIC_WHATSAPP=

# ADK session persistence (stores chat history and agent state in Firestore)
SESSION_STORE=memory                   # memory | firestore

# --- Twilio (WhatsApp + Phone) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=      # whatsapp:+E164 (shared number)
TWILIO_PHONE_NUMBER=         # +E164 (same underlying number, Phase C)
TWILIO_WEBHOOK_BASE_URL=     # public https base, e.g. https://xxxx.ngrok.app

# Phone channel (real-time Gemini Live + Twilio Media Streams)
# Vertex publisher model id (the AI-Studio "...-preview" name is rejected by Vertex)
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_LIVE_VOICE=Kore
# Browser softphone (Twilio Voice access tokens)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
# Public wss base for the <Stream> URL (falls back to TWILIO_WEBHOOK_BASE_URL with https->wss)
PUBLIC_WSS_BASE_URL=
# Token endpoint hardening (it is unauthenticated — a public SPA calls it).
# Origin allowlist reuses FRONTEND_ORIGINS. Short TTL + per-IP rate limit below.
PHONE_TOKEN_TTL_SECONDS=300
PHONE_TOKEN_RATE_LIMIT=10
PHONE_TOKEN_RATE_WINDOW_SECONDS=60

# Email channel (Zendesk-native). Reuses ZENDESK_SUPPORT_WEBHOOK_SECRET for webhook auth.
# Set to true to have the AI post replies as PRIVATE notes for an agent to send (draft-assist),
# instead of auto-emailing the customer.
EMAIL_DRAFT_ASSIST=false

# Bot-metrics dashboard (Zendesk -> BigQuery sync)
BIGQUERY_PROJECT_ID=lv-playground-genai
BIGQUERY_DATASET=demo_proton
BIGQUERY_CONVERSATIONS_TABLE=conversations

# Bot-metrics Phase 2 (per-turn streaming). "noop" (default) disables per-turn
# emit; "bigquery" streams one row per turn into the turn_events table.
METRICS_PROVIDER=noop
BIGQUERY_TURN_EVENTS_TABLE=turn_events

# Bot-metrics Phase 2 (in-app Chatwoot->BQ sync scheduler / the "trigger").
# false (default) = no scheduler; true = refresh the conversations table every
# METRICS_SYNC_INTERVAL_HOURS while the backend runs. Needs the same Chatwoot +
# BigQuery creds the manual sync (scripts/sync_chatwoot_metrics.py) uses.
METRICS_SYNC_ENABLED=false
METRICS_SYNC_INTERVAL_HOURS=6

# Bot-metrics Phase 4 (manual QA accuracy/quality entry). "noop" (default)
# disables the BigQuery write; "bigquery" writes labels to the qa_labels table.
# QA_API_KEY gates POST /qa/label (X-API-Key header); empty = endpoint locked.
QA_PROVIDER=noop
BIGQUERY_QA_LABELS_TABLE=qa_labels
QA_API_KEY=

# Bot-metrics Phase 5 (FAQ feedback recording)
BIGQUERY_FAQ_FEEDBACK_TABLE=faq_feedback

# Bot-metrics export: SMTP settings for scheduled report emails
# Report emails are DISABLED by default (REPORT_ENABLED=false).
# Set REPORT_ENABLED=true and configure SMTP_* to activate.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=noreply@example.com
# Comma-separated list of recipient addresses
#REPORT_RECIPIENTS=admin@example.com,ops@example.com
#REPORT_ENABLED=false
#REPORT_INTERVAL_HOURS=24

# Bot-metrics anomaly detection thresholds
# Z-score multiplier (higher = fewer alerts). Default: 3.0
#ANOMALY_ZSCORE_K=3.0
# Minimum baseline mean volume before a channel can be flagged (low-traffic guard). Default: 20
#ANOMALY_MIN_BASELINE=20
