diff --git a/app/javascript/dashboard/views/ProtonAppHost.vue b/app/javascript/dashboard/views/ProtonAppHost.vue
new file mode 100644
index 0000000..5aece94
--- /dev/null
+++ b/app/javascript/dashboard/views/ProtonAppHost.vue
@@ -0,0 +1,44 @@
+<template>
+  <div class="proton-app-host" style="width:100%;height:100%;display:flex;flex-direction:column;">
+    <iframe
+      ref="frame"
+      :src="iframeSrc"
+      allow="same-origin"
+      style="width:100%;flex:1;border:none;"
+      @load="postAuthMessage"
+    />
+  </div>
+</template>
+
+<script setup>
+import { computed, ref } from 'vue';
+import { useRoute } from 'vue-router';
+import { useMapGetter } from 'dashboard/composables/store';
+import { useProtonConfig } from 'dashboard/composables/useProtonConfig';
+
+const route = useRoute();
+const frame = ref(null);
+const { backendUrl } = useProtonConfig();
+
+const accountId = useMapGetter('getCurrentAccountId');
+const currentUser = useMapGetter('getCurrentUser');
+const authToken = computed(() => currentUser.value?.access_token ?? '');
+const locale = computed(() => currentUser.value?.locale ?? 'en');
+
+const iframeSrc = computed(() => {
+  const app = route.params.appName;
+  const params = new URLSearchParams({
+    account_id: accountId.value,
+    locale: locale.value,
+  });
+  return `${backendUrl}/apps/${app}?${params}`;
+});
+
+function postAuthMessage() {
+  if (!backendUrl) return;
+  frame.value?.contentWindow?.postMessage(
+    { type: 'PROTON_AUTH', accountId: accountId.value, token: authToken.value },
+    backendUrl,
+  );
+}
+</script>
