index 0000000..636fbd5
--- /dev/null
+++ b/app/javascript/dashboard/api/protonKnowledge.js
@@ -0,0 +1,50 @@
+import { useProtonConfig } from 'dashboard/composables/useProtonConfig';
+
+// Thin client for the Proton backend Knowledge endpoints (/kb/*). Auth is the
+// shared PROTON_BACKEND_KEY sent as x-api-key; the backend's CORS allows the
+// crm.* origin for /kb/* so these run straight from the dashboard. Errors carry
+// a numeric `.status` so callers can special-case 401/503.
+async function kbRequest(path, { method = 'GET', body } = {}) {
+  const { backendUrl, backendKey } = useProtonConfig();
+  if (!backendUrl) throw new Error('PROTON_BACKEND_URL not configured');
+
+  const response = await fetch(`${backendUrl}${path}`, {
+    method,
+    headers: {
+      'Content-Type': 'application/json',
+      ...(backendKey ? { 'x-api-key': backendKey } : {}),
+    },
+    ...(body ? { body: JSON.stringify(body) } : {}),
+  });
+
+  if (!response.ok) {
+    const text = await response.text().catch(() => response.statusText);
+    const err = new Error(`${response.status}: ${text.slice(0, 200)}`);
+    err.status = response.status;
+    throw err;
+  }
+  const text = await response.text();
+  return text ? JSON.parse(text) : {};
+}
+
+// GET /kb/faq -> [{ id, question, answer, keywords, tags, active }]
+export async function listFaqs() {
+  const data = await kbRequest('/kb/faq');
+  return Array.isArray(data.entries) ? data.entries : [];
+}
+
+// body: { question, answer, keywords: [], tags: [], active: bool }
+export function createFaq(entry) {
+  return kbRequest('/kb/faq', { method: 'POST', body: entry });
+}
+
+export function updateFaq(id, entry) {
+  return kbRequest(`/kb/faq/${encodeURIComponent(id)}`, {
+    method: 'PUT',
+    body: entry,
+  });
+}
+
+export function deleteFaq(id) {
+  return kbRequest(`/kb/faq/${encodeURIComponent(id)}`, { method: 'DELETE' });
+}
diff --git a/app/javascript/dashboard/components/proton/KnowledgeFaqs.vue b/app/javascript/dashboard/components/proton/KnowledgeFaqs.vue
