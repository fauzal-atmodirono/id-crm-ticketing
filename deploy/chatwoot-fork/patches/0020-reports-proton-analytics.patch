diff --git a/app/javascript/shared/components/charts/DoughnutChart.vue b/app/javascript/shared/components/charts/DoughnutChart.vue
new file mode 100644
index 0000000..fa72d3d
--- /dev/null
+++ b/app/javascript/shared/components/charts/DoughnutChart.vue
@@ -0,0 +1,31 @@
+<script setup>
+import { computed } from 'vue';
+import { Doughnut } from 'vue-chartjs';
+import { Chart as ChartJS, Title, Tooltip, Legend, ArcElement } from 'chart.js';
+
+const props = defineProps({
+  collection: {
+    type: Object,
+    default: () => ({}),
+  },
+  chartOptions: {
+    type: Object,
+    default: () => ({}),
+  },
+});
+
+ChartJS.register(Title, Tooltip, Legend, ArcElement);
+
+const defaultChartOptions = {
+  responsive: true,
+  maintainAspectRatio: false,
+};
+
+const options = computed(() => {
+  return { ...defaultChartOptions, ...props.chartOptions };
+});
+</script>
+
+<template>
+  <Doughnut :data="collection" :options="options" />
+</template>
