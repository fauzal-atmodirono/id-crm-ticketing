@@ -88,3 +88,18 @@ export function deleteAssistant(id) {
     method: 'DELETE',
   });
 }
+
+// ── Tenant settings ───────────────────────────────────────────────────────────
+
+// GET /kb/settings -> { <key>: { value, source: "override"|"env" } }
+export async function getSettings() {
+  const data = await kbRequest('/kb/settings');
+  return data.settings || {};
+}
+
+// PUT /kb/settings  body: partial { key: value } (null or "" clears override)
+// Returns updated settings map { <key>: { value, source } }
+export async function updateSettings(body) {
+  const data = await kbRequest('/kb/settings', { method: 'PUT', body });
+  return data.settings || {};
+}
