@@ -0,0 +1,61 @@
+<!-- ProtonKnowledgeHost.vue — OUR file. Left-nav "Knowledge" host: renders the
+     live Knowledge Manager for the FAQs section (embedded from the agent host)
+     and clean placeholders for the sections still being built. -->
+<script setup>
+import { computed } from 'vue';
+import { useRoute } from 'vue-router';
+import { useProtonConfig } from 'dashboard/composables/useProtonConfig';
+
+const route = useRoute();
+const { backendUrl, backendKey } = useProtonConfig();
+
+const SECTIONS = {
+  faqs: 'FAQs',
+  documents: 'Documents',
+  playground: 'Playground',
+  inboxes: 'Inboxes',
+  tools: 'Tools',
+  settings: 'Settings',
+};
+
+const section = computed(() => route.params.section || 'faqs');
+const sectionLabel = computed(() => SECTIONS[section.value] || section.value);
+
+// The Knowledge Manager is served by the agent host (derive crm.* -> agent.*)
+// and reads ?backend=&key= from its own URL — same values our other UI uses.
+const agentBase = window.location.origin.replace('://crm.', '://agent.');
+const faqsSrc = computed(
+  () =>
+    `${agentBase}/apps/knowledge-manager?backend=${encodeURIComponent(
+      backendUrl
+    )}&key=${encodeURIComponent(backendKey)}`
+);
+</script>
+
+<template>
+  <div class="flex flex-col w-full h-full bg-n-background">
+    <div
+      class="flex items-center flex-shrink-0 h-12 px-4 border-b border-n-weak"
+    >
+      <span class="text-sm font-medium text-n-slate-12">
+        Knowledge / {{ sectionLabel }}
+      </span>
+    </div>
+
+    <iframe
+      v-if="section === 'faqs'"
+      :src="faqsSrc"
+      class="flex-1 w-full"
+      style="border: none"
+    />
+    <div
+      v-else
+      class="flex flex-col items-center justify-center flex-1 gap-2 text-center"
+    >
+      <span class="text-base font-medium text-n-slate-12">{{ sectionLabel }}</span>
+      <span class="max-w-sm text-sm text-n-slate-11">
+        Coming soon — this section of our Knowledge console is being built.
+      </span>
+    </div>
+  </div>
+</template>
