+++ b/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonCallCentre.vue
@@ -0,0 +1,541 @@
+<script setup>
+import { ref, computed, onMounted } from 'vue';
+import BarChart from 'shared/components/charts/BarChart.vue';
+import ReportMetricCard from './components/ReportMetricCard.vue';
+import { getCallCentre } from 'dashboard/api/protonMetrics';
+
+// ── Data ──────────────────────────────────────────────────────────────────────
+
+const sla = ref([]);
+const tasksPerAgent = ref([]);
+const firstResponse = ref([]);
+const resolutionTime = ref([]);
+const complaintTypes = ref([]);
+const peakHours = ref([]);
+const npsByAgent = ref([]);
+const error = ref(null);
+const loading = ref(true);
+
+onMounted(async () => {
+  try {
+    const result = await getCallCentre();
+    sla.value = result.sla ?? [];
+    tasksPerAgent.value = result.tasks_per_agent ?? [];
+    firstResponse.value = result.first_response ?? [];
+    resolutionTime.value = result.resolution_time ?? [];
+    complaintTypes.value = result.complaint_types ?? [];
+    peakHours.value = result.peak_hours ?? [];
+    npsByAgent.value = result.nps_by_agent ?? [];
+  } catch (e) {
+    error.value = e.message || 'Failed to load call-centre data';
+  } finally {
+    loading.value = false;
+  }
+});
+
+// ── Helpers ───────────────────────────────────────────────────────────────────
+
+const fmtNum = (n, decimals = 1) => {
+  if (n == null || Number.isNaN(Number(n))) return '—';
+  return Number(n).toLocaleString(undefined, {
+    minimumFractionDigits: decimals,
+    maximumFractionDigits: decimals,
+  });
+};
+
+const fmtPct = n => {
+  if (n == null || Number.isNaN(Number(n))) return '—';
+  return `${(Number(n) * 100).toFixed(1)}%`;
+};
+
+const barChartOptions = {
+  plugins: { legend: { display: false } },
+  scales: { y: { beginAtZero: true } },
+};
+
+const barChartOptionsDual = {
+  plugins: { legend: { display: true } },
+  scales: { y: { beginAtZero: true } },
+};
+
+// ── Section 1: SLA Achievement ────────────────────────────────────────────────
+
+const overallSlaAchievement = computed(() => {
+  const totalMet = sla.value.reduce((s, r) => s + (r.met ?? 0), 0);
+  const totalWith = sla.value.reduce((s, r) => s + (r.with_sla ?? 0), 0);
+  if (!totalWith) return '—';
+  return `${((totalMet / totalWith) * 100).toFixed(1)}%`;
+});
+
+const slaChartCollection = computed(() => {
+  if (!sla.value.length) return null;
+  return {
+    labels: sla.value.map(r => r.channel ?? '—'),
+    datasets: [
+      {
+        label: 'SLA Achievement %',
+        backgroundColor: '#6366f1',
+        data: sla.value.map(r =>
+          r.sla_achievement_rate != null
+            ? Number((r.sla_achievement_rate * 100).toFixed(1))
+            : 0
+        ),
+      },
+    ],
+  };
+});
+
+// ── Section 2: Tasks per Agent — sorted by cases desc ────────────────────────
+
+const sortedTasksPerAgent = computed(() =>
+  [...tasksPerAgent.value].sort((a, b) => (b.cases ?? 0) - (a.cases ?? 0))
+);
+
+// ── Section 3: First Response by Channel ─────────────────────────────────────
+
+const firstResponseCollection = computed(() => {
+  if (!firstResponse.value.length) return null;
+  return {
+    labels: firstResponse.value.map(r => r.channel ?? '—'),
+    datasets: [
+      {
+        label: 'Avg First Response (min)',
+        backgroundColor: '#6366f1',
+        data: firstResponse.value.map(r =>
+          r.avg_first_response_min != null
+            ? Number(Number(r.avg_first_response_min).toFixed(1))
+            : 0
+        ),
+      },
+      {
+        label: 'P90 First Response (min)',
+        backgroundColor: '#f59e0b',
+        data: firstResponse.value.map(r =>
+          r.p90_first_response_min != null
+            ? Number(Number(r.p90_first_response_min).toFixed(1))
+            : 0
+        ),
+      },
+    ],
+  };
+});
+
+// ── Section 4: Resolution Time by Channel ────────────────────────────────────
+
+const resolutionTimeCollection = computed(() => {
+  if (!resolutionTime.value.length) return null;
+  return {
+    labels: resolutionTime.value.map(r => r.channel ?? '—'),
+    datasets: [
+      {
+        label: 'Avg Resolution (min)',
+        backgroundColor: '#6366f1',
+        data: resolutionTime.value.map(r =>
+          r.avg_min != null ? Number(Number(r.avg_min).toFixed(1)) : 0
+        ),
+      },
+      {
+        label: 'P90 Resolution (min)',
+        backgroundColor: '#f59e0b',
+        data: resolutionTime.value.map(r =>
+          r.p90_min != null ? Number(Number(r.p90_min).toFixed(1)) : 0
+        ),
+      },
+    ],
+  };
+});
+
+// ── Section 5: Complaint-type ranking — top 15, sorted by cases desc ─────────
+
+const sortedComplaintTypes = computed(() =>
+  [...complaintTypes.value]
+    .sort((a, b) => (b.cases ?? 0) - (a.cases ?? 0))
+    .slice(0, 15)
+);
+
+// ── Section 6: Peak Hours — aggregate by hour_of_day ─────────────────────────
+
+const peakHoursCollection = computed(() => {
+  if (!peakHours.value.length) return null;
+
+  const hourMap = {};
+  for (let h = 0; h < 24; h += 1) hourMap[h] = 0;
+  peakHours.value.forEach(r => {
+    const h = r.hour_of_day;
+    if (h != null) hourMap[h] = (hourMap[h] ?? 0) + (r.volume ?? 0);
+  });
+
+  const labels = Array.from({ length: 24 }, (_, i) =>
+    String(i).padStart(2, '0')
+  );
+  return {
+    labels,
+    datasets: [
+      {
+        label: 'Volume',
+        backgroundColor: '#6366f1',
+        data: labels.map((_, h) => hourMap[h] ?? 0),
+      },
+    ],
+  };
+});
+
+// ── Section 7: NPS by Agent ───────────────────────────────────────────────────
+
+// Blended agent NPS = respondent-weighted average
+const blendedNps = computed(() => {
+  const totalRespondents = npsByAgent.value.reduce(
+    (s, r) => s + (r.respondents ?? 0),
+    0
+  );
+  if (!totalRespondents) return '—';
+  const weighted = npsByAgent.value.reduce(
+    (s, r) => s + (r.nps ?? 0) * (r.respondents ?? 0),
+    0
+  );
+  return `${(weighted / totalRespondents).toFixed(1)}`;
+});
+
+// Group nps_by_agent by agent_id, show one bar per agent (avg nps across channels)
+const npsChartCollection = computed(() => {
+  if (!npsByAgent.value.length) return null;
+
+  // Aggregate by agent: respondent-weighted NPS per agent
+  const agentMap = {};
+  npsByAgent.value.forEach(r => {
+    const id = r.agent_id ?? 'Unknown';
+    if (!agentMap[id]) agentMap[id] = { weighted: 0, respondents: 0 };
+    agentMap[id].weighted += (r.nps ?? 0) * (r.respondents ?? 0);
+    agentMap[id].respondents += r.respondents ?? 0;
+  });
+
+  const agents = Object.keys(agentMap);
+  return {
+    labels: agents,
+    datasets: [
+      {
+        label: 'Agent NPS',
+        backgroundColor: '#6366f1',
+        data: agents.map(id => {
+          const { weighted, respondents } = agentMap[id];
+          return respondents ? Number((weighted / respondents).toFixed(1)) : 0;
+        }),
+      },
+    ],
+  };
+});
+</script>
+
+<template>
+  <div class="flex flex-col gap-6 px-6 py-5">
+    <!-- Loading state -->
+    <woot-loading-state
+      v-if="loading"
+      class="text-xs"
+      message="Loading call-centre data…"
+    />
+
+    <!-- Error state -->
+    <div
+      v-else-if="error"
+      class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+    >
+      {{ error }}
+    </div>
+
+    <template v-else>
+      <!-- Section 1: SLA Achievement -->
+      <div
+        class="shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5"
+      >
+        <h3 class="text-sm font-semibold text-n-slate-12 mb-4">
+          SLA Achievement
+        </h3>
+
+        <div
+          v-if="!sla.length"
+          class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+        >
+          No SLA data available
+        </div>
+
+        <template v-else>
+          <!-- KPI card for overall SLA -->
+          <div class="flex flex-wrap gap-4 mb-6">
+            <ReportMetricCard
+              label="Overall SLA Achievement"
+              info-text="Total met SLA tickets divided by total tickets with SLA across all channels"
+              :value="overallSlaAchievement"
+              class="flex-1"
+            />
+          </div>
+
+          <!-- Bar chart by channel -->
+          <div class="h-64">
+            <BarChart
+              :collection="slaChartCollection"
+              :chart-options="barChartOptions"
+            />
+          </div>
+        </template>
+      </div>
+
+      <!-- Section 2: Tasks per Agent -->
+      <div
+        class="shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5"
+      >
+        <h3 class="text-sm font-semibold text-n-slate-12 mb-4">
+          Tasks per Agent
+        </h3>
+
+        <div
+          v-if="!sortedTasksPerAgent.length"
+          class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+        >
+          No agent task data available
+        </div>
+
+        <div v-else class="overflow-x-auto">
+          <table class="w-full text-sm">
+            <thead>
+              <tr class="border-b border-n-container">
+                <th
+                  class="text-left py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Agent ID
+                </th>
+                <th
+                  class="text-left py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  PIC
+                </th>
+                <th
+                  class="text-right py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Cases
+                </th>
+                <th
+                  class="text-right py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Avg First Response (min)
+                </th>
+                <th
+                  class="text-right py-2 pr-4 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Avg Resolution (min)
+                </th>
+                <th
+                  class="text-right py-2 font-medium text-n-slate-11 whitespace-nowrap"
+                >
+                  Resolved Cases
+                </th>
+              </tr>
+            </thead>
+            <tbody>
+              <tr
+                v-for="(row, idx) in sortedTasksPerAgent"
+                :key="`${row.agent_id}-${idx}`"
+                class="border-b border-n-container last:border-0"
+              >
+                <td class="py-3 pr-4 text-n-slate-12">
+                  {{ row.agent_id ?? '—' }}
+                </td>
+                <td class="py-3 pr-4 text-n-slate-12">
+                  {{ row.pic ?? '—' }}
+                </td>
+                <td class="py-3 pr-4 text-right text-n-slate-12">
+                  {{ fmtNum(row.cases, 0) }}
+                </td>
+                <td class="py-3 pr-4 text-right text-n-slate-11">
+                  {{ fmtNum(row.avg_first_response_min) }}
+                </td>
+                <td class="py-3 pr-4 text-right text-n-slate-11">
+                  {{ fmtNum(row.avg_resolution_min) }}
+                </td>
+                <td class="py-3 text-right text-n-slate-11">
+                  {{ fmtNum(row.resolved_cases, 0) }}
+                </td>
+              </tr>
+            </tbody>
+          </table>
+        </div>
+      </div>
+
+      <!-- Section 3: First Response by Channel -->
+      <div
+        class="shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5"
+      >
+        <h3 class="text-sm font-semibold text-n-slate-12 mb-4">
+          First Response by Channel
+        </h3>
+
+        <div
+          v-if="!firstResponse.length"
+          class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+        >
+          No first-response data available
+        </div>
+
+        <div v-else class="h-64">
+          <BarChart
+            :collection="firstResponseCollection"
+            :chart-options="barChartOptionsDual"
+          />
+        </div>
+      </div>
+
+      <!-- Section 4: Resolution Time by Channel -->
+      <div
+        class="shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5"
+      >
+        <h3 class="text-sm font-semibold text-n-slate-12 mb-4">
