--- a/app/javascript/dashboard/api/protonKnowledge.js
+++ b/app/javascript/dashboard/api/protonKnowledge.js
@@ -55,3 +55,36 @@ export async function listDocuments() {
   const data = await kbRequest('/kb/documents');
   return Array.isArray(data.documents) ? data.documents : [];
 }
+
+// ── Assistants ────────────────────────────────────────────────────────────────
+
+// GET /kb/assistants -> [{ id, name, description, product_name, config, enabled, is_default, created_at }]
+export async function listAssistants() {
+  const data = await kbRequest('/kb/assistants');
+  return Array.isArray(data.assistants) ? data.assistants : [];
+}
+
+// body: { name, description, product_name } -> { id }
+export function createAssistant(body) {
+  return kbRequest('/kb/assistants', { method: 'POST', body });
+}
+
+// GET /kb/assistants/{id}
+export function getAssistant(id) {
+  return kbRequest(`/kb/assistants/${encodeURIComponent(id)}`);
+}
+
+// PUT /kb/assistants/{id}
+export function updateAssistant(id, body) {
+  return kbRequest(`/kb/assistants/${encodeURIComponent(id)}`, {
+    method: 'PUT',
+    body,
+  });
+}
+
+// DELETE /kb/assistants/{id} — 409 if it is the default
+export function deleteAssistant(id) {
+  return kbRequest(`/kb/assistants/${encodeURIComponent(id)}`, {
+    method: 'DELETE',
+  });
+}
