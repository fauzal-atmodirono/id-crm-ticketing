diff --git a/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonAnalytics.vue b/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonAnalytics.vue
new file mode 100644
index 0000000..2e2735a
--- /dev/null
+++ b/app/javascript/dashboard/routes/dashboard/settings/reports/ProtonAnalytics.vue
@@ -0,0 +1,490 @@
+<script setup>
+import { ref, computed, onMounted } from 'vue';
+import ReportMetricCard from './components/ReportMetricCard.vue';
+import BarChart from 'shared/components/charts/BarChart.vue';
+import DoughnutChart from 'shared/components/charts/DoughnutChart.vue';
+import { getDashboard, exportUrl } from 'dashboard/api/protonMetrics';
+
+// ── Data ──────────────────────────────────────────────────────────────────────
+
+const data = ref(null);
+const error = ref(null);
+const loading = ref(true);
+
+onMounted(async () => {
+  try {
+    data.value = await getDashboard();
+  } catch (e) {
+    error.value = e.message || 'Failed to load analytics';
+  } finally {
+    loading.value = false;
+  }
+});
+
+// ── KPI helpers ───────────────────────────────────────────────────────────────
+
+const fmt = (n, decimals = 0) => {
+  if (n == null || Number.isNaN(Number(n))) return '--';
+  return Number(n).toLocaleString(undefined, {
+    minimumFractionDigits: decimals,
+    maximumFractionDigits: decimals,
+  });
+};
+
+const fmtPct = (n, decimals = 1) => {
+  if (n == null || Number.isNaN(Number(n))) return '--';
+  return `${Number(n).toFixed(decimals)}%`;
+};
+
+// Total conversations – sum of volume[].volume
+const kpiTotalConversations = computed(() => {
+  const rows = data.value?.volume ?? [];
+  if (!rows.length) return '--';
+  const total = rows.reduce((acc, r) => acc + (r.volume ?? 0), 0);
+  return fmt(total);
+});
+
+// Bot-resolved % – sum(closed_by_bot) / sum(total) * 100
+const kpiBotResolved = computed(() => {
+  const rows = data.value?.resolution ?? [];
+  if (!rows.length) return '--';
+  const totalBot = rows.reduce((acc, r) => acc + (r.closed_by_bot ?? 0), 0);
+  const totalAll = rows.reduce((acc, r) => acc + (r.total ?? 0), 0);
+  if (!totalAll) return '--';
+  return fmtPct((totalBot / totalAll) * 100);
+});
+
+// CSAT – respondent-weighted avg of avg_score
+const kpiCsat = computed(() => {
+  const rows = data.value?.csat ?? [];
+  if (!rows.length) return '--';
+  const totalRespondents = rows.reduce(
+    (acc, r) => acc + (r.respondents ?? 0),
+    0
+  );
+  if (!totalRespondents) return '--';
+  const weighted = rows.reduce(
+    (acc, r) => acc + (r.avg_score ?? 0) * (r.respondents ?? 0),
+    0
+  );
+  return fmt(weighted / totalRespondents, 2);
+});
+
+// NPS – respondent-weighted avg of nps
+const kpiNps = computed(() => {
+  const rows = data.value?.nps ?? [];
+  if (!rows.length) return '--';
+  const totalRespondents = rows.reduce(
+    (acc, r) => acc + (r.respondents ?? 0),
+    0
+  );
+  if (!totalRespondents) {
+    // fallback: simple avg
+    const sum = rows.reduce((acc, r) => acc + (r.nps ?? 0), 0);
+    return fmt(sum / rows.length, 1);
+  }
+  const weighted = rows.reduce(
+    (acc, r) => acc + (r.nps ?? 0) * (r.respondents ?? 0),
+    0
+  );
+  return fmt(weighted / totalRespondents, 1);
+});
+
+// ── Chart palettes ────────────────────────────────────────────────────────────
+
+const CHANNEL_COLORS = [
+  '#6366f1',
+  '#22d3ee',
+  '#f59e0b',
+  '#10b981',
+  '#f43f5e',
+  '#8b5cf6',
+  '#ec4899',
+  '#14b8a6',
+  '#f97316',
+  '#3b82f6',
+];
+
+const getColor = i => CHANNEL_COLORS[i % CHANNEL_COLORS.length];
+
+// ── Volume by channel (BarChart, x=month, datasets=channels) ─────────────────
+
+const volumeCollection = computed(() => {
+  const rows = data.value?.volume ?? [];
+  if (!rows.length) return null;
+
+  const months = [...new Set(rows.map(r => r.month))].sort();
+  const channels = [...new Set(rows.map(r => r.channel))];
+
+  // index: [month][channel] = volume
+  const idx = {};
+  rows.forEach(r => {
+    if (!idx[r.month]) idx[r.month] = {};
+    idx[r.month][r.channel] = r.volume ?? 0;
+  });
+
+  return {
+    labels: months,
+    datasets: channels.map((ch, i) => ({
+      label: ch,
+      backgroundColor: getColor(i),
+      data: months.map(m => idx[m]?.[ch] ?? 0),
+    })),
+  };
+});
+
+const stackedBarOptions = {
+  scales: {
+    x: { stacked: true },
+    y: { stacked: true, beginAtZero: true },
+  },
+  plugins: { legend: { display: true } },
+};
+
+// ── Resolution split (DoughnutChart) ─────────────────────────────────────────
+
+const resolutionCollection = computed(() => {
+  const rows = data.value?.resolution ?? [];
+  if (!rows.length) return null;
+  const bot = rows.reduce((acc, r) => acc + (r.closed_by_bot ?? 0), 0);
+  const agent = rows.reduce((acc, r) => acc + (r.transfer_to_agent ?? 0), 0);
+  return {
+    labels: ['Bot Resolved', 'Transferred to Agent'],
+    datasets: [
+      {
+        data: [bot, agent],
+        backgroundColor: ['#6366f1', '#22d3ee'],
+      },
+    ],
+  };
+});
+
+// ── NPS split (DoughnutChart) ─────────────────────────────────────────────────
+
+const npsCollection = computed(() => {
+  const rows = data.value?.nps ?? [];
+  if (!rows.length) return null;
+  const promoters = rows.reduce((acc, r) => acc + (r.promoters ?? 0), 0);
+  const passives = rows.reduce((acc, r) => acc + (r.passives ?? 0), 0);
+  const detractors = rows.reduce((acc, r) => acc + (r.detractors ?? 0), 0);
+  return {
+    labels: ['Promoters', 'Passives', 'Detractors'],
+    datasets: [
+      {
+        data: [promoters, passives, detractors],
+        backgroundColor: ['#10b981', '#f59e0b', '#f43f5e'],
+      },
+    ],
+  };
+});
+
+// ── Speed p99 by channel (BarChart, grouped by is_first_turn) ────────────────
+
+const speedCollection = computed(() => {
+  const rows = data.value?.speed ?? [];
+  if (!rows.length) return null;
+  const channels = [...new Set(rows.map(r => r.channel))];
+  const turns = [...new Set(rows.map(r => r.is_first_turn))];
+
+  return {
+    labels: channels,
+    datasets: turns.map((turn, i) => ({
+      label: turn ? 'First Turn' : 'Subsequent Turn',
+      backgroundColor: getColor(i),
+      data: channels.map(ch => {
+        const row = rows.find(
+          r => r.channel === ch && r.is_first_turn === turn
+        );
+        return row?.p99_latency_ms ?? 0;
+      }),
+    })),
+  };
+});
+
+const groupedBarOptions = {
+  plugins: { legend: { display: true } },
+  scales: { y: { beginAtZero: true } },
+};
+
+// ── Fallback & bounce (BarChart, by channel) ──────────────────────────────────
+
+const fallbackCollection = computed(() => {
+  const rows = data.value?.fallback ?? [];
+  if (!rows.length) return null;
+  const channels = rows.map(r => r.channel);
+  return {
+    labels: channels,
+    datasets: [
+      {
+        label: 'Fallback Rate',
+        backgroundColor: '#f59e0b',
+        data: rows.map(r => (r.fallback_rate ?? 0) * 100),
+      },
+    ],
+  };
+});
+
+const bounceCollection = computed(() => {
+  const rows = data.value?.bounce ?? [];
+  if (!rows.length) return null;
+  const channels = rows.map(r => r.channel);
+  return {
+    labels: channels,
+    datasets: [
+      {
+        label: 'Bounce Rate',
+        backgroundColor: '#f43f5e',
+        data: rows.map(r => (r.bounce_rate ?? 0) * 100),
+      },
+    ],
+  };
+});
+
+// ── Quality (BarChart, avg_accuracy + avg_quality by channel) ─────────────────
+
+const qualityCollection = computed(() => {
+  const rows = data.value?.quality ?? [];
+  if (!rows.length) return null;
+  const channels = rows.map(r => r.channel);
+  return {
+    labels: channels,
+    datasets: [
+      {
+        label: 'Avg Accuracy',
+        backgroundColor: '#6366f1',
+        data: rows.map(r => r.avg_accuracy ?? 0),
+      },
+      {
+        label: 'Avg Quality',
+        backgroundColor: '#10b981',
+        data: rows.map(r => r.avg_quality ?? 0),
+      },
+    ],
+  };
+});
+
+const pctBarOptions = {
+  plugins: { legend: { display: true } },
+  scales: { y: { beginAtZero: true, max: 100 } },
+};
+
+// ── Export helpers ────────────────────────────────────────────────────────────
+
+const openExport = format => {
+  window.open(exportUrl(format), '_blank');
+};
+</script>
+
+<template>
+  <div class="flex flex-col gap-6 px-6 py-5">
+    <!-- Header row: title + export buttons -->
+    <div class="flex items-center justify-between">
+      <h2 class="text-base font-semibold text-n-slate-12">Analytics</h2>
+      <div class="flex gap-2">
+        <button
+          class="inline-flex items-center gap-1 rounded-lg border border-n-weak bg-n-solid-2 px-3 py-1.5 text-xs font-medium text-n-slate-12 hover:bg-n-solid-3 transition-colors"
+          @click="openExport('xlsx')"
+        >
+          Download Excel
+        </button>
+        <button
+          class="inline-flex items-center gap-1 rounded-lg border border-n-weak bg-n-solid-2 px-3 py-1.5 text-xs font-medium text-n-slate-12 hover:bg-n-solid-3 transition-colors"
+          @click="openExport('pdf')"
+        >
+          Download PDF
+        </button>
+      </div>
+    </div>
+
+    <!-- Loading / error state -->
+    <woot-loading-state
+      v-if="loading"
+      class="text-xs"
+      message="Loading analytics…"
+    />
+
+    <div
+      v-else-if="error"
+      class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+    >
+      {{ error }}
+    </div>
+
+    <template v-else>
+      <!-- KPI Cards -->
+      <div
+        class="flex flex-wrap mx-0 shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5 gap-4"
+      >
+        <ReportMetricCard
+          label="Total Conversations"
+          info-text="Sum of all conversations across channels"
+          :value="kpiTotalConversations"
+          class="flex-1"
+        />
+        <ReportMetricCard
+          label="Bot Resolved %"
+          info-text="Percentage of conversations closed by the bot"
+          :value="kpiBotResolved"
+          class="flex-1"
+        />
+        <ReportMetricCard
+          label="CSAT Score"
+          info-text="Respondent-weighted average CSAT score"
+          :value="kpiCsat"
+          class="flex-1"
+        />
+        <ReportMetricCard
+          label="NPS"
+          info-text="Net Promoter Score (respondent-weighted average)"
+          :value="kpiNps"
+          class="flex-1"
+        />
+      </div>
+
+      <!-- Volume by Channel -->
+      <div
+        class="shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5"
+      >
+        <h3 class="text-sm font-semibold text-n-slate-12 mb-4">
+          Volume by Channel
+        </h3>
+        <div v-if="volumeCollection" class="h-72">
+          <BarChart
+            :collection="volumeCollection"
+            :chart-options="stackedBarOptions"
+          />
+        </div>
+        <div
+          v-else
+          class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+        >
+          No volume data available
+        </div>
+      </div>
+
