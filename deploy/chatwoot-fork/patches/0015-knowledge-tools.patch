@@ -106,6 +106,48 @@ export function askPlayground(assistantId, thread, conversationId) {
   });
 }
 
+// ── Tools ─────────────────────────────────────────────────────────────────────
+
+// GET /kb/tools -> { builtins: [{name, enabled, description}], custom: [{slug, title, ...}] }
+// Secrets / auth_config are never returned; has_auth is a bool.
+export async function listTools() {
+  const data = await kbRequest('/kb/tools');
+  return {
+    builtins: Array.isArray(data.builtins) ? data.builtins : [],
+    custom: Array.isArray(data.custom) ? data.custom : [],
+  };
+}
+
+// POST /kb/tools  body: { title, description, endpoint_url, http_method, auth_type,
+//   auth_config, param_schema, request_template, response_template, enabled }
+// -> { slug }
+export function createTool(body) {
+  return kbRequest('/kb/tools', { method: 'POST', body });
+}
+
+// PUT /kb/tools/{slug}  partial update
+export function updateTool(slug, body) {
+  return kbRequest(`/kb/tools/${encodeURIComponent(slug)}`, {
+    method: 'PUT',
+    body,
+  });
+}
+
+// DELETE /kb/tools/{slug}
+export function deleteTool(slug) {
+  return kbRequest(`/kb/tools/${encodeURIComponent(slug)}`, {
+    method: 'DELETE',
+  });
+}
+
+// PUT /kb/tools/builtins/{name}  body: { enabled?, description? }
+export function setBuiltinTool(name, body) {
+  return kbRequest(`/kb/tools/builtins/${encodeURIComponent(name)}`, {
+    method: 'PUT',
+    body,
+  });
+}
+
 // ── Tenant settings ───────────────────────────────────────────────────────────
 
 // GET /kb/settings -> { <key>: { value, source: "override"|"env" } }
