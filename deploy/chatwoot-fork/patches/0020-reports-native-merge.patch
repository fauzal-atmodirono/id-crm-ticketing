+<script setup>
+import { ref, computed, onMounted } from 'vue';
+import BarChart from 'shared/components/charts/BarChart.vue';
+import ReportMetricCard from '../ReportMetricCard.vue';
+import { getCallCentre } from 'dashboard/api/protonMetrics';
+
+// ── State ──────────────────────────────────────────────────────────────────────
+
+const sla = ref([]);
+const error = ref(null);
+const loading = ref(true);
+
+onMounted(async () => {
+  try {
+    const result = await getCallCentre();
+    sla.value = result.sla ?? [];
+  } catch (e) {
+    error.value = e.message || 'Failed to load SLA data';
+  } finally {
+    loading.value = false;
+  }
+});
+
+// ── Computed ───────────────────────────────────────────────────────────────────
+
+const overallSlaAchievement = computed(() => {
+  const totalMet = sla.value.reduce((s, r) => s + (r.met ?? 0), 0);
+  const totalWith = sla.value.reduce((s, r) => s + (r.with_sla ?? 0), 0);
+  if (!totalWith) return '—';
+  return `${((totalMet / totalWith) * 100).toFixed(1)}%`;
+});
+
+const slaChartCollection = computed(() => {
+  if (!sla.value.length) return null;
+  return {
+    labels: sla.value.map(r => r.channel ?? '—'),
+    datasets: [
+      {
+        label: 'SLA Achievement %',
+        backgroundColor: '#6366f1',
+        data: sla.value.map(r =>
+          r.sla_achievement_rate != null &&
+          !Number.isNaN(Number(r.sla_achievement_rate))
+            ? Number((r.sla_achievement_rate * 100).toFixed(1))
+            : 0
+        ),
+      },
+    ],
+  };
+});
+
+const barChartOptions = {
+  plugins: { legend: { display: false } },
+  scales: { y: { beginAtZero: true } },
+};
+</script>
+
+<template>
+  <div
+    class="shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5"
+  >
+    <h3 class="text-sm font-semibold text-n-slate-12 mb-4">
+      Cross-Channel SLA Achievement
+    </h3>
+
+    <!-- Loading state -->
+    <woot-loading-state
+      v-if="loading"
+      class="text-xs"
+      message="Loading SLA data…"
+    />
+
+    <!-- Error state -->
+    <div
+      v-else-if="error"
+      class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+    >
+      {{ error }}
+    </div>
+
+    <!-- Empty state -->
+    <div
+      v-else-if="!sla.length"
+      class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+    >
+      No SLA data available
+    </div>
+
+    <!-- Content -->
+    <template v-else>
+      <div class="flex flex-wrap gap-4 mb-6">
+        <ReportMetricCard
+          label="Overall SLA Achievement"
+          info-text="Total met SLA tickets divided by total tickets with SLA across all channels"
+          :value="overallSlaAchievement"
+          class="flex-1"
+        />
+      </div>
+
+      <div class="h-64">
+        <BarChart
+          :collection="slaChartCollection"
+          :chart-options="barChartOptions"
+        />
+      </div>
+    </template>
+  </div>
+</template>
