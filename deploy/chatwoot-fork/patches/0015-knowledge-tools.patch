+<!-- KnowledgeTools.vue — OUR file. Native Knowledge console "Tools" section.
+     Three areas:
+       1. Built-in tool registry — toggle enabled / edit description per tool.
+       2. Custom webhook tool registry — full CRUD via a modal.
+       3. Per-assistant enablement — AssistantSelector header; checkboxes for
+          which registry tools each assistant may call; saved to
+          assistant.config.enabled_builtin_tools / enabled_custom_tools.
+
+     Self-contained, n-* design tokens, no woot-* imports.  Follows the same
+     load/loading/errored pattern as KnowledgeFaqs.vue. -->
+<script setup>
+import { ref, computed, watch, onMounted } from 'vue';
+import { useAlert } from 'dashboard/composables';
+import {
+  listTools,
+  createTool,
+  updateTool,
+  deleteTool,
+  setBuiltinTool,
+  getAssistant,
+  updateAssistant,
+} from 'dashboard/api/protonKnowledge';
+import { useKnowledgeAssistant } from 'dashboard/composables/useKnowledgeAssistant';
+import AssistantSelector from 'dashboard/components/proton/AssistantSelector.vue';
+
+// ── Registry state ─────────────────────────────────────────────────────────────
+const loading = ref(false);
+const errored = ref(false);
+const builtins = ref([]);
+const custom = ref([]);
+
+// Per-row saving state for built-ins (keyed by name).
+const builtinSaving = ref({});
+
+const load = async () => {
+  loading.value = true;
+  errored.value = false;
+  try {
+    const data = await listTools();
+    builtins.value = data.builtins;
+    custom.value = data.custom;
+  } catch (err) {
+    errored.value = true;
+    if (err.status === 401) {
+      useAlert('Unauthorized (401) — check the backend key configuration.');
+    } else {
+      useAlert(`Failed to load tools: ${err.message}`);
+    }
+  } finally {
+    loading.value = false;
+  }
+};
+
+// ── Built-in tool handlers ─────────────────────────────────────────────────────
+const saveBuiltin = async tool => {
+  builtinSaving.value = { ...builtinSaving.value, [tool.name]: true };
+  try {
+    await setBuiltinTool(tool.name, {
+      enabled: tool.enabled,
+      description: tool.description,
+    });
+    useAlert(`"${tool.name}" updated.`);
+  } catch (err) {
+    useAlert(`Failed to update built-in tool: ${err.message}`);
+  } finally {
+    builtinSaving.value = { ...builtinSaving.value, [tool.name]: false };
+  }
+};
+
+// ── Custom tool modal ──────────────────────────────────────────────────────────
+const modalOpen = ref(false);
+const saving = ref(false);
+const editingSlug = ref(null);
+
+const EMPTY_FORM = () => ({
+  title: '',
+  description: '',
+  endpoint_url: '',
+  http_method: 'GET',
+  auth_type: 'none',
+  // auth_config fields — write-only, never prefilled on edit
+  bearer_token: '',
+  basic_username: '',
+  basic_password: '',
+  apikey_header: '',
+  apikey_value: '',
+  param_schema: '',
+  request_template: '',
+  response_template: '',
+  enabled: true,
+});
+
+const form = ref(EMPTY_FORM());
+const paramSchemaError = ref('');
+
+const modalTitle = computed(() =>
+  editingSlug.value ? 'Edit custom tool' : 'New custom tool'
+);
+
+const openNew = () => {
+  editingSlug.value = null;
+  form.value = EMPTY_FORM();
+  paramSchemaError.value = '';
+  modalOpen.value = true;
+};
+
+const openEdit = tool => {
+  editingSlug.value = tool.slug;
+  form.value = {
+    ...EMPTY_FORM(),
+    title: tool.title || '',
+    description: tool.description || '',
+    endpoint_url: tool.endpoint_url || '',
+    http_method: tool.http_method || 'GET',
+    auth_type: tool.auth_type || 'none',
+    param_schema:
+      tool.param_schema ? JSON.stringify(tool.param_schema, null, 2) : '',
+    request_template: tool.request_template || '',
+    response_template: tool.response_template || '',
+    enabled: tool.enabled !== false,
+    // auth secret fields intentionally left blank (write-only)
+  };
+  paramSchemaError.value = '';
+  modalOpen.value = true;
+};
+
+const closeModal = () => {
+  modalOpen.value = false;
+};
+
+const buildAuthConfig = () => {
+  const t = form.value.auth_type;
+  if (t === 'bearer') {
+    return form.value.bearer_token
+      ? { token: form.value.bearer_token }
+      : undefined;
+  }
+  if (t === 'basic') {
+    if (form.value.basic_username || form.value.basic_password) {
+      return {
+        username: form.value.basic_username,
+        password: form.value.basic_password,
+      };
+    }
+    return undefined;
+  }
+  if (t === 'api_key') {
+    if (form.value.apikey_header || form.value.apikey_value) {
+      return {
+        header_name: form.value.apikey_header,
+        value: form.value.apikey_value,
+      };
+    }
+    return undefined;
+  }
+  return undefined;
+};
+
+const validateParamSchema = raw => {
+  if (!raw.trim()) return null; // empty is allowed (no schema constraints)
+  try {
+    const parsed = JSON.parse(raw);
+    if (typeof parsed !== 'object' || Array.isArray(parsed) || !parsed.type) {
+      return 'param_schema must be a JSON object with a "type" field.';
+    }
+    return null;
+  } catch (_e) {
+    return 'param_schema is not valid JSON.';
+  }
+};
+
+const save = async () => {
+  const title = form.value.title.trim();
+  if (!title) {
+    useAlert('Title is required.');
+    return;
+  }
+  const url = form.value.endpoint_url.trim();
+  if (!url.startsWith('https://')) {
+    useAlert('Endpoint URL must start with https://');
+    return;
+  }
+
+  const schemaRaw = form.value.param_schema.trim();
+  const schemaErr = validateParamSchema(schemaRaw);
+  if (schemaErr) {
+    paramSchemaError.value = schemaErr;
+    return;
+  }
+  paramSchemaError.value = '';
+
+  const body = {
+    title,
+    description: form.value.description.trim(),
+    endpoint_url: url,
+    http_method: form.value.http_method,
+    auth_type: form.value.auth_type,
+    param_schema: schemaRaw ? JSON.parse(schemaRaw) : undefined,
+    request_template: form.value.request_template.trim() || undefined,
+    response_template: form.value.response_template.trim() || undefined,
+    enabled: form.value.enabled,
+  };
+
+  const authConfig = buildAuthConfig();
+  if (authConfig) body.auth_config = authConfig;
+
+  saving.value = true;
+  try {
+    if (editingSlug.value) {
+      await updateTool(editingSlug.value, body);
+      useAlert('Tool updated.');
+    } else {
+      await createTool(body);
+      useAlert('Tool created.');
+    }
+    closeModal();
+    await load();
+    // Re-sync enablement panel to reflect any new slugs
+    if (selectedId.value) {
+      await loadEnablement(selectedId.value);
+    }
+  } catch (err) {
+    // Surface 409 (dup slug / cap) and 422 (validation) with the server message.
+    useAlert(`Save failed: ${err.message}`);
+  } finally {
+    saving.value = false;
+  }
+};
+
+const remove = async tool => {
+  // eslint-disable-next-line no-alert
+  if (!window.confirm(`Delete the tool "${tool.title}"? This cannot be undone.`)) {
+    return;
+  }
+  try {
+    await deleteTool(tool.slug);
+    useAlert('Tool deleted.');
+    await load();
+    if (selectedId.value) {
+      await loadEnablement(selectedId.value);
+    }
+  } catch (err) {
+    useAlert(`Delete failed: ${err.message}`);
+  }
+};
+
+// ── Per-assistant enablement ───────────────────────────────────────────────────
+const { selectedId, assistants, refresh: refreshAssistants } = useKnowledgeAssistant();
+
+const enablementLoading = ref(false);
+const enablementSaving = ref(false);
+const enabledBuiltins = ref([]); // names
+const enabledCustom = ref([]);   // slugs
+
+const loadEnablement = async id => {
+  if (!id) return;
+  enablementLoading.value = true;
+  try {
+    const assistant = await getAssistant(id);
+    const cfg = assistant.config || {};
+    enabledBuiltins.value = Array.isArray(cfg.enabled_builtin_tools)
+      ? cfg.enabled_builtin_tools
+      : [];
+    enabledCustom.value = Array.isArray(cfg.enabled_custom_tools)
+      ? cfg.enabled_custom_tools
+      : [];
+  } catch (err) {
+    useAlert(`Failed to load assistant: ${err.message}`);
+  } finally {
+    enablementLoading.value = false;
+  }
+};
+
+const toggleBuiltinEnabled = name => {
+  if (enabledBuiltins.value.includes(name)) {
+    enabledBuiltins.value = enabledBuiltins.value.filter(n => n !== name);
+  } else {
+    enabledBuiltins.value = [...enabledBuiltins.value, name];
+  }
+};
+
+const toggleCustomEnabled = slug => {
+  if (enabledCustom.value.includes(slug)) {
+    enabledCustom.value = enabledCustom.value.filter(s => s !== slug);
+  } else {
+    enabledCustom.value = [...enabledCustom.value, slug];
+  }
+};
+
+const saveEnablement = async () => {
+  if (!selectedId.value) {
+    useAlert('Select an assistant first.');
+    return;
+  }
+  enablementSaving.value = true;
+  try {
+    await updateAssistant(selectedId.value, {
+      config: {
+        enabled_builtin_tools: enabledBuiltins.value,
+        enabled_custom_tools: enabledCustom.value,
+      },
+    });
+    useAlert('Enablement saved.');
+  } catch (err) {
+    useAlert(`Failed to save enablement: ${err.message}`);
+  } finally {
+    enablementSaving.value = false;
+  }
+};
+
+watch(selectedId, id => {
+  if (id) loadEnablement(id);
+});
+
+onMounted(async () => {
+  await load();
+  if (!assistants.value.length) {
+    await refreshAssistants();
+  }
+  if (selectedId.value) {
+    await loadEnablement(selectedId.value);
+  }
+});
+</script>
