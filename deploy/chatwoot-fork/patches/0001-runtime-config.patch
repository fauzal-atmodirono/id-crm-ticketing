index 0000000..8c72f82
--- /dev/null
+++ b/app/javascript/dashboard/composables/useProtonConfig.js
@@ -0,0 +1,9 @@
+export function useProtonConfig() {
+  const cfg = window.__PROTON_CONFIG__ || { backendUrl: '', backendKey: '', features: [] };
+  return {
+    backendUrl: cfg.backendUrl,
+    backendKey: cfg.backendKey,
+    features: Array.isArray(cfg.features) ? cfg.features : [],
+    hasFeature: (name) => Array.isArray(cfg.features) && cfg.features.includes(name),
+  };
+}
