diff --git a/app/javascript/dashboard/components/proton/KnowledgeDocuments.vue b/app/javascript/dashboard/components/proton/KnowledgeDocuments.vue
new file mode 100644
index 0000000..c71c714
--- /dev/null
+++ b/app/javascript/dashboard/components/proton/KnowledgeDocuments.vue
@@ -0,0 +1,129 @@
+<!-- KnowledgeDocuments.vue — OUR file. Read-only listing of the tenant's Vertex
+     AI Search data store (the bulk KB that grounds Suggest/Copilot), so agents
+     and admins can see the grounding corpus from inside the CRM. Native,
+     Chatwoot-styled; talks to the Proton backend's GET /kb/documents. Upload /
+     delete are intentionally out of scope for v1. -->
+<script setup>
+import { ref, computed, onMounted } from 'vue';
+import { useAlert } from 'dashboard/composables';
+import { listDocuments } from 'dashboard/api/protonKnowledge';
+
+const documents = ref([]);
+const loading = ref(false);
+const errored = ref(false);
+const search = ref('');
+
+const filtered = computed(() => {
+  const q = search.value.trim().toLowerCase();
+  if (!q) return documents.value;
+  return documents.value.filter(d =>
+    [d.title, d.uri, d.snippet].join(' ').toLowerCase().includes(q)
+  );
+});
+
+const load = async () => {
+  loading.value = true;
+  errored.value = false;
+  try {
+    documents.value = await listDocuments();
+  } catch (err) {
+    errored.value = true;
+    if (err.status === 401) {
+      useAlert('Unauthorized (401) — check the backend key configuration.');
+    } else {
+      useAlert(`Failed to load documents: ${err.message}`);
+    }
+  } finally {
+    loading.value = false;
+  }
+};
+
+onMounted(load);
+</script>
+
+<template>
+  <div class="flex flex-col w-full h-full">
+    <div
+      class="flex items-center flex-shrink-0 gap-3 px-4 py-3 border-b border-n-weak"
+    >
+      <button
+        class="px-3 py-1.5 text-sm font-medium rounded-lg text-n-slate-12 border border-n-weak hover:bg-n-alpha-black1"
+        :disabled="loading"
+        @click="load"
+      >
+        Refresh
+      </button>
+      <input
+        v-model="search"
+        type="text"
+        placeholder="Filter by title, URL, snippet…"
+        class="flex-1 max-w-xs px-3 py-1.5 text-sm border rounded-lg border-n-weak bg-n-alpha-black1 text-n-slate-12 focus:outline-none"
+      />
+      <span class="ml-auto text-xs text-n-slate-11">
+        {{ documents.length }} document{{ documents.length === 1 ? '' : 's' }}
+      </span>
+    </div>
+
+    <div class="flex-1 p-4 overflow-auto">
+      <div v-if="loading" class="py-10 text-sm text-center text-n-slate-11">
+        Loading documents…
+      </div>
+      <div
+        v-else-if="errored"
+        class="py-10 text-sm text-center text-n-slate-11"
+      >
+        Could not load documents.
+      </div>
+      <div
+        v-else-if="!filtered.length"
+        class="py-10 text-sm text-center text-n-slate-11"
+      >
+        {{
+          documents.length
+            ? 'No documents match the filter.'
+            : 'No documents indexed in the Vertex AI Search data store yet.'
+        }}
+      </div>
+      <div
+        v-else
+        class="overflow-hidden border rounded-lg border-n-weak bg-n-background"
+      >
+        <table class="w-full text-sm border-collapse">
+          <thead>
+            <tr class="text-left border-b border-n-weak bg-n-alpha-black1">
+              <th class="px-3 py-2 font-medium text-n-slate-11">Title</th>
+              <th class="px-3 py-2 font-medium text-n-slate-11">URL</th>
+              <th class="px-3 py-2 font-medium text-n-slate-11">Snippet</th>
+            </tr>
+          </thead>
+          <tbody>
+            <tr
+              v-for="doc in filtered"
+              :key="doc.id"
+              class="border-b border-n-weak last:border-0 align-top"
+            >
+              <td class="px-3 py-2 font-medium text-n-slate-12">
+                {{ doc.title }}
+              </td>
+              <td class="px-3 py-2">
+                <a
+                  v-if="doc.uri"
+                  :href="doc.uri"
+                  target="_blank"
+                  rel="noopener"
+                  class="break-all text-n-brand hover:underline"
+                >
+                  {{ doc.uri }}
+                </a>
+                <span v-else class="text-n-slate-10">—</span>
+              </td>
+              <td class="px-3 py-2 text-n-slate-11 max-w-md">
+                {{ doc.snippet || '—' }}
+              </td>
+            </tr>
+          </tbody>
+        </table>
+      </div>
+    </div>
+  </div>
+</template>
