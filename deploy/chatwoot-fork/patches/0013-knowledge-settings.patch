+<!-- KnowledgeSettings.vue — Two-panel Knowledge Settings page.
+     Panel 1: per-assistant persona editor (name, description, product_name,
+     instructions, temperature, guardrails, response guidelines, messages,
+     feature toggles). Panel 2: tenant-wide ops knobs (models, iterations,
+     debounce, feature gates, mode) with override/env badges and per-field
+     reset. Both panels share the AssistantSelector in the header so the
+     assistant context is always visible. Self-contained, n-* tokens, useAlert.
+     No woot-* imports, no new deps, script setup. -->
+<script setup>
+import { ref, watch, onMounted } from 'vue';
+import { useAlert } from 'dashboard/composables';
+import { useKnowledgeAssistant } from 'dashboard/composables/useKnowledgeAssistant';
+import AssistantSelector from 'dashboard/components/proton/AssistantSelector.vue';
+import {
+  getAssistant,
+  updateAssistant,
+  getSettings,
+  updateSettings,
+} from 'dashboard/api/protonKnowledge';
+
+// ── Shared assistant state ────────────────────────────────────────────────────
+const { selectedId, refresh: refreshList } = useKnowledgeAssistant();
+
+// ── Panel 1 — Assistant persona ───────────────────────────────────────────────
+const assistantLoading = ref(false);
+const assistantErrored = ref(false);
+const assistantSaving = ref(false);
+
+// Flat editable form — we reconstruct nested config on save.
+const aForm = ref({
+  name: '',
+  description: '',
+  product_name: '',
+  instructions: '',
+  temperature: 1,
+  guardrails: [],
+  response_guidelines: [],
+  welcome_message: '',
+  handoff_message: '',
+  resolution_message: '',
+  feature_faq: true,
+  feature_memory: false,
+  feature_citations: false,
+  feature_contact_attributes: false,
+});
+
+// Scratch inputs for the list editors.
+const guardrailInput = ref('');
+const guidelineInput = ref('');
+
+const loadAssistant = async id => {
+  if (!id) return;
+  assistantLoading.value = true;
+  assistantErrored.value = false;
+  try {
+    const data = await getAssistant(id);
+    const a = data.assistant || data; // backend may wrap or return flat
+    const cfg = a.config || {};
+    aForm.value = {
+      name: a.name || '',
+      description: a.description || '',
+      product_name: a.product_name || '',
+      instructions: cfg.instructions || '',
+      temperature: cfg.temperature !== undefined ? cfg.temperature : 1,
+      guardrails: Array.isArray(cfg.guardrails) ? [...cfg.guardrails] : [],
+      response_guidelines: Array.isArray(cfg.response_guidelines)
+        ? [...cfg.response_guidelines]
+        : [],
+      welcome_message: cfg.welcome_message || '',
+      handoff_message: cfg.handoff_message || '',
+      resolution_message: cfg.resolution_message || '',
+      feature_faq: cfg.feature_faq !== false,
+      feature_memory: cfg.feature_memory === true,
+      feature_citations: cfg.feature_citations === true,
+      feature_contact_attributes: cfg.feature_contact_attributes === true,
+    };
+  } catch (err) {
+    assistantErrored.value = true;
+    if (err.status === 401) {
+      useAlert('Unauthorized (401) — check the backend key configuration.');
+    } else {
+      useAlert(`Failed to load assistant: ${err.message}`);
+    }
+  } finally {
+    assistantLoading.value = false;
+  }
+};
+
+// List editor helpers — guardrails
+const addGuardrail = () => {
+  const val = guardrailInput.value.trim();
+  if (val && !aForm.value.guardrails.includes(val)) {
+    aForm.value.guardrails = [...aForm.value.guardrails, val];
+  }
+  guardrailInput.value = '';
+};
+const removeGuardrail = idx => {
+  aForm.value.guardrails = aForm.value.guardrails.filter((_, i) => i !== idx);
+};
+
+// List editor helpers — response guidelines
+const addGuideline = () => {
+  const val = guidelineInput.value.trim();
+  if (val && !aForm.value.response_guidelines.includes(val)) {
+    aForm.value.response_guidelines = [...aForm.value.response_guidelines, val];
+  }
+  guidelineInput.value = '';
+};
+const removeGuideline = idx => {
+  aForm.value.response_guidelines = aForm.value.response_guidelines.filter(
+    (_, i) => i !== idx
+  );
+};
+
+const saveAssistant = async () => {
+  if (!selectedId.value) return;
+  const f = aForm.value;
+  if (!f.name.trim()) {
+    useAlert('Name is required.');
+    return;
+  }
+  assistantSaving.value = true;
+  try {
+    await updateAssistant(selectedId.value, {
+      name: f.name.trim(),
+      description: f.description.trim(),
+      product_name: f.product_name.trim(),
+      config: {
+        instructions: f.instructions,
+        temperature: f.temperature,
+        guardrails: f.guardrails,
+        response_guidelines: f.response_guidelines,
+        welcome_message: f.welcome_message,
+        handoff_message: f.handoff_message,
+        resolution_message: f.resolution_message,
+        feature_faq: f.feature_faq,
+        feature_memory: f.feature_memory,
+        feature_citations: f.feature_citations,
+        feature_contact_attributes: f.feature_contact_attributes,
+      },
+    });
+    useAlert('Assistant saved.');
+    await refreshList();
+    await loadAssistant(selectedId.value);
+  } catch (err) {
+    useAlert(`Save failed: ${err.message}`);
+  } finally {
+    assistantSaving.value = false;
+  }
+};
+
+// Reload when the selected assistant changes.
+watch(selectedId, id => {
+  if (id) loadAssistant(id);
+});
+
+// ── Panel 2 — Tenant settings ─────────────────────────────────────────────────
+const settingsLoading = ref(false);
+const settingsErrored = ref(false);
+const settingsSaving = ref(false);
+
+// Live settings map: { key: { value, source } }
+const settingsMap = ref({});
+
+// Editable draft values (strings for inputs; converted on save).
+const sDraft = ref({
+  assist_gemini_model: '',
+  copilot_gemini_model: '',
+  copilot_max_tool_iterations: '',
+  feature_ai_assist: false,
+  feature_copilot: false,
+  feature_drafts: false,
+  default_mode: 'suggest',
+  debounce_seconds: '',
+});
+
+const SETTINGS_KEYS = [
+  'assist_gemini_model',
+  'copilot_gemini_model',
+  'copilot_max_tool_iterations',
+  'feature_ai_assist',
+  'feature_copilot',
+  'feature_drafts',
+  'default_mode',
+  'debounce_seconds',
+];
+
+// Keys treated as booleans.
+const BOOL_KEYS = new Set(['feature_ai_assist', 'feature_copilot', 'feature_drafts']);
+// Keys that are numeric.
+const NUM_KEYS = new Set(['copilot_max_tool_iterations', 'debounce_seconds']);
+
+const applySettings = map => {
+  settingsMap.value = map;
+  SETTINGS_KEYS.forEach(key => {
+    const entry = map[key];
+    const raw = entry ? entry.value : undefined;
+    if (BOOL_KEYS.has(key)) {
+      sDraft.value[key] = raw === true || raw === 'true' || raw === 1;
+    } else if (NUM_KEYS.has(key)) {
+      sDraft.value[key] = raw !== undefined && raw !== null ? String(raw) : '';
+    } else {
+      sDraft.value[key] = raw !== undefined && raw !== null ? String(raw) : '';
+    }
+  });
+};
+
+const loadSettings = async () => {
+  settingsLoading.value = true;
+  settingsErrored.value = false;
+  try {
+    const map = await getSettings();
+    applySettings(map);
+  } catch (err) {
+    settingsErrored.value = true;
+    if (err.status === 401) {
+      useAlert('Unauthorized (401) — check the backend key configuration.');
+    } else {
+      useAlert(`Failed to load settings: ${err.message}`);
+    }
+  } finally {
+    settingsLoading.value = false;
+  }
+};
+
+const resetField = async key => {
+  try {
+    const updated = await updateSettings({ [key]: null });
+    applySettings(updated);
+    useAlert(`"${key}" reset to env default.`);
+  } catch (err) {
+    useAlert(`Reset failed: ${err.message}`);
+  }
+};
+
+const saveSettings = async () => {
+  settingsSaving.value = true;
+  try {
+    // Build a partial of only changed/override values — we send all editable
+    // fields; backend ignores unchanged ones vs env (it always stores a delta).
+    const body = {};
+    SETTINGS_KEYS.forEach(key => {
+      const draft = sDraft.value[key];
+      if (BOOL_KEYS.has(key)) {
+        body[key] = draft === true || draft === 'true';
+      } else if (NUM_KEYS.has(key)) {
+        const num = draft === '' || draft === null ? null : Number(draft);
+        body[key] = Number.isNaN(num) ? null : num;
+      } else {
+        body[key] = draft === '' ? null : draft;
+      }
+    });
+    const updated = await updateSettings(body);
+    applySettings(updated);
+    useAlert('Settings saved.');
+  } catch (err) {
+    useAlert(`Save failed: ${err.message}`);
+  } finally {
+    settingsSaving.value = false;
+  }
+};
+
+const sourceLabel = key => {
+  const entry = settingsMap.value[key];
+  return entry ? entry.source : null;
+};
+
+// ── Lifecycle ─────────────────────────────────────────────────────────────────
+onMounted(() => {
+  if (selectedId.value) loadAssistant(selectedId.value);
+  loadSettings();
+});
+</script>
