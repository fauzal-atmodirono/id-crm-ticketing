+    0
+  );
+  if (!totalRespondents) return '—';
+  const weighted = csat.value.reduce(
+    (s, r) => s + (r.avg_score ?? 0) * (r.respondents ?? 0),
+    0
+  );
+  const result = weighted / totalRespondents;
+  if (Number.isNaN(Number(result))) return '—';
+  return `${Number(result).toFixed(1)}/5`;
+});
+
+// ── KPI: Blended NPS (respondent-weighted avg of nps) ────────────────────────
+
+const blendedNps = computed(() => {
+  if (!nps.value.length) return '—';
+  const totalRespondents = nps.value.reduce(
+    (s, r) => s + (r.respondents ?? 0),
+    0
+  );
+  if (!totalRespondents) return '—';
+  const weighted = nps.value.reduce(
+    (s, r) => s + (r.nps ?? 0) * (r.respondents ?? 0),
+    0
+  );
+  const result = weighted / totalRespondents;
+  if (Number.isNaN(Number(result))) return '—';
+  return Number(result).toFixed(1);
+});
+
+// ── Chart options ─────────────────────────────────────────────────────────────
+
+const barChartOptions = {
+  plugins: { legend: { display: false } },
+  scales: { y: { beginAtZero: true } },
+};
+
+// ── CSAT by channel (BarChart) ────────────────────────────────────────────────
+
+const csatChartCollection = computed(() => {
+  if (!csat.value.length) return null;
+  return {
+    labels: csat.value.map(r => r.channel ?? '—'),
+    datasets: [
+      {
+        label: 'Avg CSAT Score',
+        backgroundColor: '#6366f1',
+        data: csat.value.map(r => {
+          const v = r.avg_score;
+          if (v == null || Number.isNaN(Number(v))) return 0;
+          return Number(Number(v).toFixed(2));
+        }),
+      },
+    ],
+  };
+});
+
+// ── NPS split doughnut (promoters / passives / detractors) ───────────────────
+
+const npsDoughnutCollection = computed(() => {
+  if (!nps.value.length) return null;
+  const promoters = nps.value.reduce((s, r) => s + (r.promoters ?? 0), 0);
+  const passives = nps.value.reduce((s, r) => s + (r.passives ?? 0), 0);
+  const detractors = nps.value.reduce((s, r) => s + (r.detractors ?? 0), 0);
+  if (!promoters && !passives && !detractors) return null;
+  return {
+    labels: ['Promoters', 'Passives', 'Detractors'],
+    datasets: [
+      {
+        data: [promoters, passives, detractors],
+        backgroundColor: ['#10b981', '#f59e0b', '#f43f5e'],
+      },
+    ],
+  };
+});
+
+// ── NPS by agent (BarChart) — respondent-weighted per agent ──────────────────
+
+const npsAgentChartCollection = computed(() => {
+  if (!npsByAgent.value.length) return null;
+
+  // Aggregate by agent_id: respondent-weighted NPS across channels
+  const agentMap = {};
+  npsByAgent.value.forEach(r => {
+    const id = r.agent_id ?? 'Unknown';
+    if (!agentMap[id]) agentMap[id] = { weighted: 0, respondents: 0 };
+    agentMap[id].weighted += (r.nps ?? 0) * (r.respondents ?? 0);
+    agentMap[id].respondents += r.respondents ?? 0;
+  });
+
+  const agents = Object.keys(agentMap);
+  return {
+    labels: agents,
+    datasets: [
+      {
+        label: 'Agent NPS',
+        backgroundColor: '#6366f1',
+        data: agents.map(id => {
+          const { weighted, respondents } = agentMap[id];
+          return respondents ? Number((weighted / respondents).toFixed(1)) : 0;
+        }),
+      },
+    ],
+  };
+});
+</script>
+
+<template>
+  <div
+    class="shadow outline-1 outline outline-n-container rounded-xl bg-n-solid-2 px-6 py-5"
+  >
+    <h3 class="text-sm font-semibold text-n-slate-12 mb-4">
+      Cross-Channel CSAT & NPS
+    </h3>
+
+    <!-- Loading state -->
+    <woot-loading-state
+      v-if="loading"
+      class="text-xs"
+      message="Loading CSAT & NPS data…"
+    />
+
+    <!-- Error state -->
+    <div
+      v-else-if="error"
+      class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+    >
+      {{ error }}
+    </div>
+
+    <!-- Empty state -->
+    <div
+      v-else-if="!csat.length && !nps.length && !npsByAgent.length"
+      class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+    >
+      No CSAT or NPS data available
+    </div>
+
+    <!-- Content -->
+    <template v-else>
+      <!-- KPI Cards -->
+      <div class="flex flex-wrap gap-4 mb-6">
+        <ReportMetricCard
+          label="Blended CSAT"
+          info-text="Respondent-weighted average CSAT score across all channels (0–5 scale)"
+          :value="blendedCsat"
+          class="flex-1"
+        />
+        <ReportMetricCard
+          label="Blended NPS"
+          info-text="Respondent-weighted average Net Promoter Score across all channels (-100 to 100)"
+          :value="blendedNps"
+          class="flex-1"
+        />
+      </div>
+
+      <!-- CSAT by Channel -->
+      <div class="mb-6">
+        <h4 class="text-xs font-medium text-n-slate-11 mb-3">
+          CSAT Score by Channel
+        </h4>
+        <div v-if="csatChartCollection" class="h-64">
+          <BarChart
+            :collection="csatChartCollection"
+            :chart-options="barChartOptions"
+          />
+        </div>
+        <div
+          v-else
+          class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+        >
+          No CSAT data available
+        </div>
+      </div>
+
+      <!-- NPS Split Doughnut -->
+      <div class="mb-6">
+        <h4 class="text-xs font-medium text-n-slate-11 mb-3">
+          NPS Respondent Split
+        </h4>
+        <div v-if="npsDoughnutCollection" class="h-64">
+          <DoughnutChart :collection="npsDoughnutCollection" />
+        </div>
+        <div
+          v-else
+          class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+        >
+          No NPS split data available
+        </div>
+      </div>
+
+      <!-- NPS by Agent -->
+      <div>
+        <h4 class="text-xs font-medium text-n-slate-11 mb-3">NPS by Agent</h4>
+        <div v-if="npsAgentChartCollection" class="h-64">
+          <BarChart
+            :collection="npsAgentChartCollection"
+            :chart-options="barChartOptions"
+          />
+        </div>
+        <div
+          v-else
+          class="flex items-center justify-center h-24 text-sm text-n-slate-10"
+        >
+          No agent NPS data available
+        </div>
+      </div>
+    </template>
+  </div>
+</template>
diff --git a/app/javascript/dashboard/routes/dashboard/settings/reports/components/proton/ProtonSlaSection.vue b/app/javascript/dashboard/routes/dashboard/settings/reports/components/proton/ProtonSlaSection.vue
