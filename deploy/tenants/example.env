# Template for a per-tenant env file. scripts/add-tenant.sh generates a real
# deploy/tenants/<tenant>.env from this shape (secrets auto-filled; agent
# tokens left blank for the operator to fill after onboarding).
#
# Bring a tenant up manually with:
#   docker compose -p <tenant> -f docker-compose.tenant.yml --env-file tenants/<tenant>.env up -d

# --- Identity --------------------------------------------------------------
TENANT=example
PUBLIC_IP=127-0-0-1
# Public-hostname label prefix. Normally "<tenant>." (e.g. proton.) so the
# tenant is served at proton.crm.<ip>.nip.io. Set empty (via add-tenant.sh
# --bare, or automatically for the tenant named "default") to serve at the
# bare crm.<ip>.nip.io hostnames. Container aliases are unaffected.
HOST_PREFIX=example.

# --- Secrets (auto-generated per tenant; no single quotes in passwords) -----
CHATWOOT_DB_PASSWORD=changeme
ZAMMAD_DB_PASSWORD=changeme
AGENT_DB_PASSWORD=changeme
REDIS_PASSWORD=changeme
SECRET_KEY_BASE=changeme

# --- Agent service config --------------------------------------------------
# Filled by the operator AFTER running the Chatwoot/Zammad setup wizards and
# generating tokens (see README §5–6). Blank is fine until then.
CHATWOOT_API_TOKEN=
CHATWOOT_PLATFORM_TOKEN=
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_WEBHOOK_SECRET=
CHATWOOT_BOT_TOKEN=
CHATWOOT_BOT_SECRET=
ZAMMAD_API_TOKEN=
ZAMMAD_WEBHOOK_SECRET=
ZAMMAD_INTEGRATION_LOGIN=integration@local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AGENT_MODE=suggest
AUTO_RESOLVE=false

# --- Conversation lifecycle & auto-close (agent service) ---
# Master switch. When false the whole feature is a no-op (default).
LIFECYCLE_ENABLED=false
# How often the scanner ticks over open/pending conversations (seconds).
LIFECYCLE_SCAN_INTERVAL_SECONDS=60
# Minutes of customer inactivity before the idle warning is posted.
LIFECYCLE_IDLE_WARN_MINUTES=10
# Grace after the warning before auto-close, IN business hours (10+5=15m total).
LIFECYCLE_IDLE_CLOSE_GRACE_MINUTES=5
# Grace after the warning before auto-close, OUTSIDE business hours (10+0=10m total).
LIFECYCLE_IDLE_CLOSE_OUT_OF_HOURS_GRACE_MINUTES=0
# Minutes to wait for a YES/NO (or rating) reply before treating as resolved.
LIFECYCLE_CONFIRM_GRACE_MINUTES=10
# Post the rating survey after resolution.
LIFECYCLE_SURVEY_ENABLED=true
# Post the AI disclaimer/welcome on conversation-created.
LIFECYCLE_DISCLAIMER_ENABLED=true
# Optionally apply a case-category label on bot auto-close (off by default).
LIFECYCLE_AUTO_CATEGORIZE=false

# --- SOP completion (agent service) ---
# Category slugs the bot may assign on resolution (comma-separated); must match
# the tenant's taxonomy. Empty disables auto-categorization even if
# LIFECYCLE_AUTO_CATEGORIZE=true.
LIFECYCLE_CATEGORY_LABELS=
# Email once-per-thread auto-acknowledgement.
EMAIL_AUTOACK_ENABLED=false
# EMAIL_AUTOACK_TEMPLATE has a built-in SOP default; override only to customize.

ZAMMAD_AI_DRAFTS=true

# --- Proton fork image & AI-assist -------------------------------------------
# Override to use the patched Chatwoot image. Empty → stock chatwoot/chatwoot:v4.15.1
CHATWOOT_IMAGE=
# Internal (server-side) base URL of this tenant's AI backend, used by the AGENT
# service over the Docker network (no trailing slash). Defaults to the in-stack
# http://<tenant>-backend:8080. Only "proton" tenant has one today; others leave
# blank (feature stays disabled).
PROTON_BACKEND_URL=
# BROWSER-facing backend origin injected into the Chatwoot SPA (window.__PROTON_CONFIG__).
# MUST be an origin the browser can reach — NOT the internal <tenant>-backend host.
# Caddy proxies /metrics,/kb,/assist on this origin to the backend, so setting it to
# the SPA's own origin (the crm vhost) means same-origin calls with no CORS.
# Defaults to http://crm.localhost for local dev; set to the public crm URL in prod.
PROTON_BACKEND_PUBLIC_URL=
# API key matching PROTON_BACKEND_KEY in the backend's Settings.
PROTON_BACKEND_KEY=
# Comma-separated feature flags. Example: ai_assist,nav_menu,copilot
# (copilot = the multi-turn Ask Copilot panel → PROTON_BACKEND_URL/assist/copilot)
# Empty → no Proton patches active even if the custom image is used.
PROTON_FEATURES=
# Phase-3 Reporting: Power BI embed URL for the Reports nav item.
# Get this from Power BI Service → Report → File → Embed report → Website or portal.
# Leave blank to show a placeholder (or use a Looker Studio URL as an alternative).
REPORTS_EMBED_URL=

# --- Phase-5 Agent Routing & Presence (set on the proton-conversational-ai backend) ---
# Master switch: true → escalations/handoffs route to an available individual agent
# by per-agent channel priority (with idle-fallback); false (default) keeps the static
# team assignment. Behavior-preserving when off. Backend Settings: routing_enabled.
ROUTING_ENABLED=false
# x-api-key guarding writes to the backend's /routing/priorities (the routing-admin
# dashboard app sends it via ?apiKey=). Empty → writes locked. Setting: routing_admin_api_key.
ROUTING_ADMIN_API_KEY=

# --- Phase-6 Task Timers & Reminders (set on the proton-conversational-ai backend) ---
# x-api-key gating GET /tasks/mine (returns customer PII). Empty → 401 for everyone
# (fail-closed). Required to enable the "My Tasks" dashboard app. Setting: tasks_api_key.
TASKS_API_KEY=
# Minutes before the resolution SLA at which My Tasks warns / a reminder fires.
TASKS_REMINDER_WARNING_MINUTES=60
# true → the SLA scan also sends a WhatsApp reminder (via the global SLA PIC number)
# as a conversation nears its resolution SLA. Requires the backend SLA engine enabled.
TASKS_REMINDER_WHATSAPP_ENABLED=false

# ============================================================================
# AI BACKEND (vendored from proton-conversational-ai; runs as ${TENANT}-backend)
# ----------------------------------------------------------------------------
# Provider selection
CRM_PROVIDER=chatwoot
KNOWLEDGE_PROVIDER=mock                 # mock | zendesk | vertex_search
VOICE_PROVIDER=mock

# Gates /kb/faq admin WRITES only (POST/PUT/DELETE). NOTE: /assist/* (the Ask
# Copilot panel) is gated by PROTON_BACKEND_KEY, set above under "Proton fork
# image & AI-assist" — not this key. The two are independent; /kb/* reads accept
# either. Leave empty to lock FAQ admin writes.
FAQ_ADMIN_API_KEY=

# Gates GET /metrics/{departments,callcenter,lifecycle} (agent/PIC-level report data)
METRICS_API_KEY=

# Gemini / Vertex. Two auth paths (see "GCP credentials" note below):
#   - GOOGLE_GENAI_USE_VERTEXAI=false + a Gemini API key (GOOGLE_API_KEY), or
#   - GOOGLE_GENAI_USE_VERTEXAI=true + GCP Application Default Credentials (set
#     GCP_ADC_PATH below) — this is how the proton backend runs.
# NOTE: GEMINI_MODEL already set above under "Agent service config".
GOOGLE_GENAI_USE_VERTEXAI=false
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# Vertex AI Search — only needed when the knowledge provider is vertex_search.
VERTEX_SEARCH_PROJECT_ID=
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_DATA_STORE_ID=
VERTEX_SEARCH_ENGINE_ID=

# Persistence: memory (default, ephemeral) or firestore (needs GCP creds + DB).
HANDOFF_STORE=memory
SESSION_STORE=memory
FIRESTORE_PROJECT_ID=
FIRESTORE_DATABASE_ID=

# Phase toggles (all default-off / behavior-preserving)
# Routing + task vars already set above under Phase-5/6 sections.
SLA_ENGINE_ENABLED=false
# Per-channel first-response (ack) SLA overrides in MINUTES (JSON object).
# Empty = global SLA_RESPONSE_HOURS for all channels. Example:
# {"whatsapp":2,"call":0.333,"facebook":120,"instagram":120,"email":240}
SLA_ACK_MINUTES_BY_CHANNEL_JSON=
METRICS_SYNC_ENABLED=false

# Escalation / PIC (Phase 2). JSON map dept->PIC; empty disables PIC notify.
PIC_MAP_JSON=

# GCP Application Default Credentials (ADC). Host path to a readable
# application_default_credentials.json (from `gcloud auth application-default
# login`) or a service-account JSON. The backend service bind-mounts it read-only
# at /gcp/adc.json and sets GOOGLE_APPLICATION_CREDENTIALS to it. Leave EMPTY to
# run without GCP (mock/off providers). Required when GOOGLE_GENAI_USE_VERTEXAI=
# true, KNOWLEDGE_PROVIDER=vertex_search, or HANDOFF_STORE/SESSION_STORE=firestore.
GCP_ADC_PATH=
# ============================================================================

# --- GCP credentials (per-tenant) ---
# The AI backend reaches Gemini/Vertex/Firestore via ADC. Point GCP_ADC_PATH
# (above) at a credentials JSON on the host; the compose backend service mounts
# it and exports GOOGLE_APPLICATION_CREDENTIALS automatically. Alternatively run
# GOOGLE_GENAI_USE_VERTEXAI=false with a Gemini API key and leave GCP_ADC_PATH
# empty. Each tenant needs its own project / data store / Firestore DB — do NOT
# point two tenants at the same FIRESTORE_PROJECT_ID + FIRESTORE_DATABASE_ID.
