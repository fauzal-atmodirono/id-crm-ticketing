+  // Distinct statuses
+  const statuses = [...new Set(stateTrend.value.map(r => r.status))];
+
+  // Build a lookup: month+status -> cases COUNT
+  const lookup = {};
+  stateTrend.value.forEach(r => {
+    lookup[`${r.month}__${r.status}`] = r.cases ?? 0;
+  });
+
+  const datasets = statuses.map((status, i) => ({
+    label: status,
+    borderColor: LINE_COLORS[i % LINE_COLORS.length],
+    backgroundColor: LINE_COLORS[i % LINE_COLORS.length],
+    fill: false,
+    tension: 0.3,
+    data: months.map(m => lookup[`${m}__${status}`] ?? 0),
+  }));
+
+  return { labels: months, datasets };
+});
+
+const lineChartOptions = {
+  plugins: { legend: { display: true, position: 'bottom' } },
+  scales: { y: { beginAtZero: true } },
+};
+
+// ── Section 3: Recent cases table (up to 50, most-recent first) ───────────────
+
+const recentCases = computed(() => {
