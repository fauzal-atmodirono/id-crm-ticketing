diff --git a/app/javascript/dashboard/components/proton/KnowledgeScenarios.vue b/app/javascript/dashboard/components/proton/KnowledgeScenarios.vue
new file mode 100644
index 0000000..683d275
--- /dev/null
+++ b/app/javascript/dashboard/components/proton/KnowledgeScenarios.vue
@@ -0,0 +1,441 @@
+<!-- KnowledgeScenarios.vue — OUR file. Native, Chatwoot-styled Scenarios page
+     for the Knowledge console. Renders per-assistant playbooks: named instruction
+     blocks that steer the assistant's behaviour when injected into the system
+     prompt. Mirrors the Captain scenarios feature (V1 prompt-injection shape).
+     Self-contained, n-* tokens, no woot-* imports. -->
+<script setup>
+import { ref, watch, onMounted, computed } from 'vue';
+import { useAlert } from 'dashboard/composables';
+import { useKnowledgeAssistant } from 'dashboard/composables/useKnowledgeAssistant';
+import AssistantSelector from 'dashboard/components/proton/AssistantSelector.vue';
+import {
+  listScenarios,
+  createScenario,
+  updateScenario,
+  deleteScenario,
+} from 'dashboard/api/protonKnowledge';
+import { listTools } from 'dashboard/api/protonKnowledge';
+
+const { selectedId } = useKnowledgeAssistant();
+
+// ── List state ────────────────────────────────────────────────────────────────
+const scenarios = ref([]);
+const loading = ref(false);
+const errored = ref(false);
+
+// ── Tool options (fetched once on mount) ──────────────────────────────────────
+// Valid tool slugs = builtin names + custom slugs, per the backend spec.
+const toolOptions = ref([]); // [{ slug, label }]
+
+const loadTools = async () => {
+  try {
+    const { builtins, custom } = await listTools();
+    toolOptions.value = [
+      ...builtins.map(b => ({ slug: b.name, label: b.name })),
+      ...custom.map(c => ({ slug: c.slug, label: c.title || c.slug })),
+    ];
+  } catch (_err) {
+    // Non-fatal: the user may still type tool slugs; the backend will validate.
+  }
+};
+
+// ── Modal state ───────────────────────────────────────────────────────────────
+const modalOpen = ref(false);
+const saving = ref(false);
+const editingId = ref(null);
+const form = ref({
+  title: '',
+  description: '',
+  instruction: '',
+  tools: [],
+  enabled: true,
+});
+
+const INSTRUCTION_MAX = 4096;
+const instructionCount = computed(() => form.value.instruction.length);
+const instructionOverLimit = computed(() => instructionCount.value > INSTRUCTION_MAX);
+
+const modalTitle = computed(() =>
+  editingId.value ? 'Edit scenario' : 'New scenario'
+);
+
+// ── Load ──────────────────────────────────────────────────────────────────────
+const load = async () => {
+  if (!selectedId.value) return;
+  loading.value = true;
+  errored.value = false;
+  try {
+    scenarios.value = await listScenarios(selectedId.value);
+  } catch (err) {
+    errored.value = true;
+    if (err.status === 401) {
+      useAlert('Unauthorized (401) — check the backend key configuration.');
+    } else if (err.status === 503) {
+      useAlert('Knowledge store unavailable (503) on the backend.');
+    } else {
+      useAlert(`Failed to load scenarios: ${err.message}`);
+    }
+  } finally {
+    loading.value = false;
+  }
+};
+
+onMounted(() => {
+  loadTools();
+  load();
+});
+
+watch(selectedId, load);
+
+// ── Enabled toggle (inline PUT) ───────────────────────────────────────────────
+const toggleEnabled = async scenario => {
+  const next = !scenario.enabled;
+  // Optimistic update
+  scenario.enabled = next;
+  try {
+    await updateScenario(scenario.id, { enabled: next });
+  } catch (err) {
+    // Revert on failure
+    scenario.enabled = !next;
+    useAlert(`Could not update: ${err.message}`);
+  }
+};
+
+// ── Modal helpers ─────────────────────────────────────────────────────────────
+const openNew = () => {
+  editingId.value = null;
+  form.value = { title: '', description: '', instruction: '', tools: [], enabled: true };
+  modalOpen.value = true;
+};
+
+const openEdit = scenario => {
+  editingId.value = scenario.id;
+  form.value = {
+    title: scenario.title || '',
+    description: scenario.description || '',
+    instruction: scenario.instruction || '',
+    tools: Array.isArray(scenario.tools) ? [...scenario.tools] : [],
+    enabled: scenario.enabled !== false,
+  };
+  modalOpen.value = true;
+};
+
+const closeModal = () => {
+  modalOpen.value = false;
+};
+
+const toggleTool = slug => {
+  const idx = form.value.tools.indexOf(slug);
+  if (idx === -1) {
+    form.value.tools = [...form.value.tools, slug];
+  } else {
+    form.value.tools = form.value.tools.filter(s => s !== slug);
+  }
+};
+
+// ── Save ──────────────────────────────────────────────────────────────────────
+const save = async () => {
+  const title = form.value.title.trim();
+  if (!title) {
+    useAlert('Title is required.');
+    return;
+  }
+  if (instructionOverLimit.value) {
+    useAlert(`Instruction must be ${INSTRUCTION_MAX} characters or fewer.`);
+    return;
+  }
+  const body = {
+    assistant_id: selectedId.value,
+    title,
+    description: form.value.description.trim(),
+    instruction: form.value.instruction.trim(),
+    tools: form.value.tools,
+    enabled: form.value.enabled,
+  };
+  saving.value = true;
+  try {
+    if (editingId.value) {
+      await updateScenario(editingId.value, body);
+      useAlert('Scenario updated.');
+    } else {
+      await createScenario(body);
+      useAlert('Scenario created.');
+    }
+    closeModal();
+    await load();
+  } catch (err) {
+    // Surface 422 / 409 messages from the server verbatim.
+    let msg = err.message || 'Save failed.';
+    // err.message is already "<status>: <server text slice>" from kbRequest.
+    useAlert(`Save failed: ${msg}`);
+  } finally {
+    saving.value = false;
+  }
+};
+
+// ── Delete ────────────────────────────────────────────────────────────────────
+const remove = async scenario => {
+  // eslint-disable-next-line no-alert
+  if (!window.confirm(`Delete scenario "${scenario.title || scenario.id}"?`)) {
+    return;
+  }
+  try {
+    await deleteScenario(scenario.id);
+    useAlert('Scenario deleted.');
+    await load();
+  } catch (err) {
+    useAlert(`Delete failed: ${err.message}`);
+  }
+};
+</script>
+
+<template>
+  <div class="flex flex-col w-full h-full">
+    <!-- Header bar -->
+    <div
+      class="flex items-center flex-shrink-0 gap-3 px-4 py-3 border-b border-n-weak"
+    >
+      <AssistantSelector />
+      <button
+        class="px-3 py-1.5 text-sm font-medium text-white rounded-lg bg-n-brand hover:brightness-95"
+        @click="openNew"
+      >
+        + New scenario
+      </button>
+      <button
+        class="px-3 py-1.5 text-sm font-medium rounded-lg text-n-slate-12 border border-n-weak hover:bg-n-alpha-black1"
+        :disabled="loading"
+        @click="load"
+      >
+        Refresh
+      </button>
+      <span class="ml-auto text-xs text-n-slate-11">
+        {{ scenarios.length }} scenario{{ scenarios.length === 1 ? '' : 's' }}
+      </span>
+    </div>
+
+    <!-- Body -->
+    <div class="flex-1 p-4 overflow-auto">
+      <div v-if="!selectedId" class="py-10 text-sm text-center text-n-slate-11">
+        Select an assistant to view its scenarios.
+      </div>
+      <div v-else-if="loading" class="py-10 text-sm text-center text-n-slate-11">
+        Loading scenarios…
+      </div>
+      <div
+        v-else-if="errored"
+        class="py-10 text-sm text-center text-n-slate-11"
+      >
+        Could not load scenarios.
+      </div>
+      <div
+        v-else-if="!scenarios.length"
+        class="py-10 text-sm text-center text-n-slate-11"
+      >
+        No scenarios yet. Click "New scenario" to create one.
+      </div>
+      <div
+        v-else
+        class="overflow-hidden border rounded-lg border-n-weak bg-n-background"
+      >
+        <table class="w-full text-sm border-collapse">
+          <thead>
+            <tr class="text-left border-b border-n-weak bg-n-alpha-black1">
+              <th class="px-3 py-2 font-medium text-n-slate-11">Title</th>
+              <th class="px-3 py-2 font-medium text-n-slate-11">Description</th>
+              <th class="px-3 py-2 font-medium text-n-slate-11">Tools</th>
+              <th class="px-3 py-2 font-medium text-n-slate-11">Enabled</th>
+              <th class="px-3 py-2 font-medium text-n-slate-11">Actions</th>
+            </tr>
+          </thead>
+          <tbody>
+            <tr
+              v-for="scenario in scenarios"
+              :key="scenario.id"
+              class="border-b border-n-weak last:border-0 align-top"
+            >
+              <td class="px-3 py-2 font-medium text-n-slate-12 whitespace-nowrap">
+                {{ scenario.title }}
+              </td>
+              <td class="px-3 py-2 text-n-slate-11 max-w-xs">
+                {{ scenario.description || '—' }}
+              </td>
+              <td class="px-3 py-2">
+                <span
+                  v-for="slug in (scenario.tools || [])"
+                  :key="slug"
+                  class="inline-block px-2 py-0.5 mr-1 mb-1 text-xs rounded-full bg-n-alpha-black2 text-n-slate-11"
+                >
+                  {{ slug }}
+                </span>
+                <span
+                  v-if="!(scenario.tools || []).length"
+                  class="text-n-slate-10"
+                >—</span>
+              </td>
+              <td class="px-3 py-2">
+                <button
+                  :title="scenario.enabled ? 'Disable' : 'Enable'"
+                  class="relative inline-flex h-5 w-9 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-150 focus:outline-none"
+                  :class="scenario.enabled ? 'bg-n-brand' : 'bg-n-alpha-black2'"
+                  @click="toggleEnabled(scenario)"
+                >
+                  <span
+                    class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow transition duration-150"
+                    :class="scenario.enabled ? 'translate-x-4' : 'translate-x-0'"
+                  />
+                </button>
+              </td>
+              <td class="px-3 py-2 whitespace-nowrap">
+                <button
+                  class="mr-2 text-xs text-n-brand hover:underline"
+                  @click="openEdit(scenario)"
+                >
+                  Edit
+                </button>
+                <button
+                  class="text-xs text-n-ruby-9 hover:underline"
+                  @click="remove(scenario)"
+                >
+                  Delete
+                </button>
+              </td>
+            </tr>
+          </tbody>
+        </table>
+      </div>
+    </div>
+
+    <!-- Create / edit modal -->
+    <div
+      v-if="modalOpen"
+      class="fixed inset-0 z-50 flex items-start justify-center px-4 py-16 overflow-y-auto bg-n-alpha-black2"
+      @click.self="closeModal"
+    >
+      <div
+        class="w-full max-w-lg p-5 rounded-xl shadow-lg bg-n-background border border-n-weak"
+      >
+        <h3 class="mb-4 text-base font-medium text-n-slate-12">
+          {{ modalTitle }}
+        </h3>
+        <form class="space-y-3" @submit.prevent="save">
+          <!-- Title -->
+          <div>
+            <label class="block mb-1 text-xs font-medium text-n-slate-11">
+              Title <span class="text-n-ruby-9">*</span>
+            </label>
+            <input
+              v-model="form.title"
+              type="text"
+              placeholder="e.g. Warranty claim handling"
+              class="w-full px-3 py-2 text-sm border rounded-lg border-n-weak bg-n-alpha-black1 text-n-slate-12 focus:outline-none"
+            />
+          </div>
+
+          <!-- Description -->
+          <div>
+            <label class="block mb-1 text-xs font-medium text-n-slate-11">Description</label>
+            <input
+              v-model="form.description"
+              type="text"
+              placeholder="Brief summary shown in the list"
+              class="w-full px-3 py-2 text-sm border rounded-lg border-n-weak bg-n-alpha-black1 text-n-slate-12 focus:outline-none"
+            />
+          </div>
+
+          <!-- Instruction -->
+          <div>
+            <label class="block mb-1 text-xs font-medium text-n-slate-11">
+              Instruction
+              <span
+                class="ml-1 font-normal"
+                :class="instructionOverLimit ? 'text-n-ruby-9' : 'text-n-slate-10'"
+              >
+                ({{ instructionCount }}&nbsp;/&nbsp;{{ INSTRUCTION_MAX }})
+              </span>
+            </label>
+            <textarea
+              v-model="form.instruction"
+              rows="6"
+              placeholder="Markdown playbook injected into the system prompt when this scenario is enabled…"
+              class="w-full px-3 py-2 text-sm border rounded-lg resize-y border-n-weak bg-n-alpha-black1 text-n-slate-12 focus:outline-none font-mono"
+            />
+            <p v-if="instructionOverLimit" class="mt-1 text-xs text-n-ruby-9">
+              Instruction exceeds the {{ INSTRUCTION_MAX }}-character limit.
+            </p>
+          </div>
+
+          <!-- Tools multi-select -->
+          <div>
+            <label class="block mb-1 text-xs font-medium text-n-slate-11">Tools</label>
+            <div
+              v-if="toolOptions.length"
+              class="max-h-36 overflow-y-auto border rounded-lg border-n-weak bg-n-alpha-black1 p-2 space-y-1"
+            >
+              <label
+                v-for="opt in toolOptions"
+                :key="opt.slug"
+                class="flex items-center gap-2 text-sm text-n-slate-12 cursor-pointer hover:text-n-brand"
+              >
+                <input
+                  type="checkbox"
+                  :checked="form.tools.includes(opt.slug)"
+                  @change="toggleTool(opt.slug)"
+                />
+                <span class="font-mono text-xs">{{ opt.slug }}</span>
+                <span v-if="opt.label !== opt.slug" class="text-n-slate-11">
+                  — {{ opt.label }}
+                </span>
+              </label>
+            </div>
+            <p v-else class="text-xs text-n-slate-10 mt-1">
+              No tools found — the assistant's tool list will appear here.
+            </p>
+            <!-- Show selected slugs even if toolOptions not loaded -->
+            <div
+              v-if="form.tools.length"
+              class="flex flex-wrap gap-1 mt-1"
+            >
+              <span
+                v-for="slug in form.tools"
+                :key="slug"
+                class="inline-flex items-center gap-1 px-2 py-0.5 text-xs rounded-full bg-n-alpha-black2 text-n-slate-11"
+              >
+                {{ slug }}
+                <button
+                  type="button"
+                  class="text-n-slate-10 hover:text-n-ruby-9 leading-none"
+                  @click="toggleTool(slug)"
+                >×</button>
+              </span>
+            </div>
+          </div>
+
+          <!-- Enabled -->
+          <label class="flex items-center gap-2 text-sm text-n-slate-12">
+            <input v-model="form.enabled" type="checkbox" />
+            Enabled (injected into the system prompt)
+          </label>
+
+          <!-- Buttons -->
+          <div class="flex justify-end gap-2 pt-2">
+            <button
+              type="button"
+              class="px-3 py-1.5 text-sm font-medium rounded-lg text-n-slate-12 border border-n-weak hover:bg-n-alpha-black1"
+              @click="closeModal"
+            >
+              Cancel
+            </button>
+            <button
+              type="submit"
+              class="px-3 py-1.5 text-sm font-medium text-white rounded-lg bg-n-brand disabled:opacity-50"
+              :disabled="saving || instructionOverLimit"
+            >
+              {{ saving ? 'Saving…' : 'Save' }}
+            </button>
+          </div>
+        </form>
+      </div>
+    </div>
+  </div>
+</template>
