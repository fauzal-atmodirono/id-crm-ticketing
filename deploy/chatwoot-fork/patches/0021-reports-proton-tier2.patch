+// ── Data ──────────────────────────────────────────────────────────────────────
+
+const deptPic = ref([]);
+const reopen = ref([]);
+const error = ref(null);
+const loading = ref(true);
+
+onMounted(async () => {
+  try {
+    const result = await getDepartments();
+    deptPic.value = result.dept_pic ?? [];
+    reopen.value = result.reopen ?? [];
